@using CollegeWebSite.Services.Implementation
@inherits LayoutComponentBase
@implements IDisposable
@inject ThemeService ThemeService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ILogger<AdminLayout> Logger

<div class="flex h-screen bg-slate-50 font-sans antialiased text-slate-900 overflow-hidden">
    <!-- Sidebar / Nav Menu Bar -->
    <aside class="fixed inset-y-0 left-0 z-50 w-64 bg-slate-900 text-white transition-all duration-300 transform md:translate-x-0 md:static md:inset-0 shadow-[20px_0_50px_rgba(0,0,0,0.2)] flex flex-col @(IsSidebarOpen ? "translate-x-0" : "-translate-x-full")">
        <!-- Brand Identity -->
        <div class="flex h-16 shrink-0 items-center gap-3 px-6 border-b border-white/5 bg-white/5">
            <div class="h-8 w-8 rounded-lg bg-primary flex items-center justify-center shadow-lg shadow-primary/20">
                <span class="font-black text-white text-xs">I</span>
            </div>
            <div class="flex flex-col">
                <span class="text-[10px] font-black tracking-[0.2em] text-white/40 uppercase leading-none">ISHIKA</span>
                <span class="text-xs font-black tracking-tight text-white mt-0.5">Control Center</span>
            </div>
        </div>

        <!-- Navigation Scroll Area -->
        <nav class="flex-1 overflow-y-auto py-6 px-4 space-y-1 custom-scrollbar">
            <!-- MANAGEMENT -->
            <div class="px-3 pb-2 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Management</div>

            <NavLink href="/admin" Match="NavLinkMatch.All" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><rect width="7" height="9" x="3" y="3" rx="1" /><rect width="7" height="5" x="14" y="3" rx="1" /><rect width="7" height="9" x="14" y="12" rx="1" /><rect width="7" height="5" x="3" y="16" rx="1" /></svg>
                <span class="text-sm font-bold">Dashboard</span>
            </NavLink>

            <NavLink href="/admin/inquiries" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                <span class="text-sm font-bold">Inquiries</span>
            </NavLink>

            <NavLink href="/admin/media" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="m22 2-7 20-4-9-9-4Z" /><path d="M22 2 11 13" /></svg>
                <span class="text-sm font-bold">Media Vault</span>
            </NavLink>

            <NavLink href="/admin/gallery" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><rect width="18" height="18" x="3" y="3" rx="2" ry="2" /><circle cx="9" cy="9" r="2" /><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" /></svg>
                <span class="text-sm font-bold">Gallery</span>
            </NavLink>

            <!-- CONTENT -->
            <div class="px-3 pt-6 pb-2 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Web Content</div>

            <NavLink href="/admin/pages" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" /><polyline points="14 2 14 8 20 8" /></svg>
                <span class="text-sm font-bold">Pages</span>
            </NavLink>

            <NavLink href="/admin/settings/hero" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="M20 7h-9M14 17H5M10 12l2-2 2 2M10 12h10M4 12h2"/></svg>
                <span class="text-sm font-bold">Hero Section</span>
            </NavLink>

            <NavLink href="/admin/popups" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="M18 8a3 3 0 0 0-3-3H5a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h12a3 3 0 0 0 3-3V8Z"/><path d="M10 12h.01"/><path d="M14 12h.01"/><path d="M18 12h.01"/></svg>
                <span class="text-sm font-bold">Announcements</span>
            </NavLink>

            <NavLink href="/admin/faculty" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                <span class="text-sm font-bold">Faculty</span>
            </NavLink>

            <NavLink href="/admin/notices" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="M18 8a3 3 0 0 0-3-3H5a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h12a3 3 0 0 0 3-3V8Z" /><path d="M6 8v12" /></svg>
                <span class="text-sm font-bold">Notices</span>
            </NavLink>

            <NavLink href="/admin/events" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><rect width="18" height="18" x="3" y="4" rx="2" ry="2" /><line x1="16" x2="16" y1="2" y2="6" /><line x1="8" x2="8" y1="2" y2="6" /><line x1="3" x2="21" y1="10" y2="10" /></svg>
                <span class="text-sm font-bold">Events</span>
            </NavLink>

            <!-- ACADEMICS -->
            <div class="px-3 pt-6 pb-2 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Academics</div>

            <NavLink href="/admin/placements" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="M22 10v6M2 10l10-5 10 5-10 5z" /><path d="M6 12v5c3 3 9 3 12 0v-5" /></svg>
                <span class="text-sm font-bold">Placements</span>
            </NavLink>

            <NavLink href="/admin/results" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="M22 7 13.5 15.5 8.5 10.5 2 17" /><polyline points="16 7 22 7 22 13" /></svg>
                <span class="text-sm font-bold">Results</span>
            </NavLink>

            <NavLink href="/admin/syllabus" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                <span class="text-sm font-bold">Syllabus</span>
            </NavLink>

            <!-- SYSTEM -->
            <div class="px-3 pt-6 pb-2 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">System</div>

            <NavLink href="/admin/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-primary transition-colors"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
                <span class="text-sm font-bold">Settings</span>
            </NavLink>

            <NavLink href="/admin/diagnostics/logs" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:bg-white/10 hover:text-white transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-red-500 transition-colors"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z" /><polyline points="13 2 13 9 20 9" /></svg>
                <span class="text-sm font-bold">Logs</span>
            </NavLink>
        </nav>

        <!-- Exit Footer -->
        <div class="p-4 border-t border-white/5 bg-white/5 shrink-0">
            <button @onclick="TerminateSession" class="flex items-center gap-3 w-full px-4 py-3 text-[10px] font-black uppercase tracking-[0.1em] text-slate-500 hover:text-white hover:bg-red-500/20 rounded-xl transition-all group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-red-500 transition-colors"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" x2="9" y1="12" y2="12" /></svg>
                <span>Exit Admin</span>
            </button>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex flex-1 flex-col overflow-hidden relative">
        <!-- Top Navigation Bar (Default Navbar) -->
        <header class="flex h-16 items-center justify-between bg-white px-4 md:px-8 shadow-sm border-b border-slate-200 shrink-0 z-30">
            <div class="flex items-center gap-4">
                <!-- Mobile Trigger -->
                <button @onclick="ToggleSidebar" class="p-2 text-slate-500 hover:text-slate-900 md:hidden rounded-lg bg-slate-50 active:scale-95 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12" /><line x1="4" x2="20" y1="6" y2="6" /><line x1="4" x2="20" y1="18" y2="18" /></svg>
                </button>
                <div class="flex flex-col">
                    <span class="text-[9px] font-black uppercase tracking-[0.2em] text-slate-400 leading-none mb-1">Administrative Office</span>
                    <h1 class="text-sm md:text-base font-black text-slate-900 tracking-tight">Institutional Dashboard</h1>
                </div>
            </div>

            <div class="flex items-center gap-3 md:gap-6">
                <div class="hidden sm:flex items-center gap-2">
                     <button class="p-2 text-slate-400 hover:text-primary transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></button>
                     <button class="p-2 text-slate-400 hover:text-primary transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v2m0 16v2m10-10h-2M4 12H2m15.36-7.36l-1.41 1.41M6.05 17.95l-1.41 1.41m12.72 0l1.41-1.41M6.05 6.05L4.64 4.64"/></svg></button>
                </div>

                <div class="flex items-center gap-2 md:gap-3 pl-3 md:pl-6 border-l border-slate-100">
                    <div class="hidden md:flex flex-col items-end">
                        <span class="text-xs font-black text-slate-900 uppercase">Administrator</span>
                        <span class="text-[9px] font-bold text-green-500 uppercase tracking-widest flex items-center gap-1">
                            <span class="h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse"></span>
                            Verified
                        </span>
                    </div>
                    <div class="h-9 w-9 md:h-10 md:w-10 rounded-xl bg-slate-950 border border-slate-800 flex items-center justify-center text-white text-xs font-black shadow-lg">
                        A
                    </div>
                </div>
            </div>
        </header>

        <!-- Page Content Scroll Area -->
        <main class="flex-1 overflow-y-auto bg-slate-50/50 p-4 md:p-6 lg:p-8 custom-scrollbar">
            <div class="max-w-7xl mx-auto">
                @Body
            </div>
        </main>
    </div>

    <!-- Mobile Drawer Overlay -->
    @if (IsSidebarOpen)
    {
        <div @onclick="CloseSidebar" class="fixed inset-0 z-40 bg-slate-950/70 backdrop-blur-sm md:hidden transition-all duration-300 animate-in fade-in">
        </div>
    }
</div>

<style>
    /* Premium Scrollbar */
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.05);
        border-radius: 20px;
    }
    aside .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.05);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(0, 0, 0, 0.1);
    }
    aside .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    /* Active Nav Link Styling */
    .active {
        background-color: rgba(255, 255, 255, 0.08) !important;
        color: white !important;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.2);
    }
    .active svg {
        color: #3b82f6; /* primary blue */
    }
</style>

@code {
    private bool IsSidebarOpen { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        // Auto-close sidebar on navigation change
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeThemeAsync();
            ThemeService.OnThemeChanged += StateHasChanged;
            StateHasChanged();
        }
    }

    private void HandleLocationChanged(object sender, LocationChangedEventArgs e)
    {
        if (IsSidebarOpen)
        {
            IsSidebarOpen = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private void ToggleSidebar() => IsSidebarOpen = !IsSidebarOpen;
    private void CloseSidebar() => IsSidebarOpen = false;

    private async Task TerminateSession()
    {
        NavigationManager.NavigateTo("/", true);
        await Task.CompletedTask;
    }
}
