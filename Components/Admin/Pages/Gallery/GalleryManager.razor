@page "/admin/gallery"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Components.Admin.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout AdminLayout
@inject IGalleryService GalleryService
@inject IMediaService MediaService

<PageTitle>Gallery Management | Ishika CMS Admin</PageTitle>

<div class="mb-8 flex flex-col lg:flex-row lg:items-end justify-between gap-4">
    <div class="space-y-2">
        <div class="inline-flex items-center gap-2 px-2.5 py-1 bg-purple-50 text-purple-600 text-[9px] font-black uppercase tracking-widest rounded-md border border-purple-100">
            Visual Narratives
        </div>
        <h1 class="text-3xl lg:text-4xl font-black text-slate-900 tracking-tight leading-none">Institutional <br/><span class="text-slate-400">Image Registry.</span></h1>
        <p class="text-slate-500 font-medium text-sm max-w-xl">Curate visual stories of campus life and clinical excellence.</p>
    </div>
    
    <div class="flex items-center gap-3">
        <button @onclick="() => OpenCategoryModal()" class="px-6 py-3 bg-white text-slate-600 font-black text-[10px] uppercase tracking-[0.2em] rounded-xl border border-slate-100 hover:bg-slate-50 transition-all shadow-sm">
            Create Category
        </button>
        <button @onclick="OpenImageUploader" class="group/btn relative px-8 py-3 bg-slate-950 text-white font-black text-[10px] uppercase tracking-[0.2em] rounded-xl shadow-2xl hover:bg-purple-600 transition-all overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/10 to-white/0 -translate-x-full group-hover/btn:animate-shimmer"></div>
            Add New Image
        </button>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Categories Sidebar -->
    <div class="lg:col-span-1 space-y-6">
        <div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-premium">
            <h3 class="text-[10px] font-black text-slate-900 uppercase tracking-widest mb-4">Categorization</h3>
            <div class="space-y-1">
                <button @onclick='() => SelectCategory(0)' class="w-full text-left px-4 py-2.5 rounded-xl transition-all @(SelectedCategoryId == 0 ? "bg-slate-900 text-white shadow-lg" : "text-slate-500 hover:bg-slate-50")">
                    <span class="text-[10px] font-black uppercase tracking-widest">Recent Captures</span>
                </button>
                @foreach(var cat in Categories)
                {
                    <div class="group relative">
                        <button @onclick='() => SelectCategory(cat.Id)' class="w-full text-left px-4 py-2.5 rounded-xl transition-all @(SelectedCategoryId == cat.Id ? "bg-slate-900 text-white shadow-lg" : "text-slate-500 hover:bg-slate-50")">
                            <span class="text-[10px] font-black uppercase tracking-widest">@cat.Name</span>
                        </button>
                        <div class="absolute right-1 top-1/2 -translate-y-1/2 flex opacity-0 group-hover:opacity-100 transition-opacity">
                             <button @onclick="() => OpenCategoryModal(cat)" class="p-1.5 text-slate-400 hover:text-blue-500"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg></button>
                             <button @onclick="() => HandleDeleteCategory(cat.Id)" class="p-1.5 text-slate-400 hover:text-red-500"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg></button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Image Grid -->
    <div class="lg:col-span-3 space-y-8">
        @if (IsLoading)
        {
            <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-5 gap-4">
                @for(int i=0; i<10; i++)
                {
                    <div class="aspect-square bg-slate-50 rounded-2xl animate-pulse"></div>
                }
            </div>
        }
        else if (Images.Any())
        {
            <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-5 gap-4">
                @foreach (var img in Images)
                {
                    <div class="group relative aspect-square bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-all overflow-hidden">
                        <OptimizedImage Media="@img.Media" 
                                        AltText="@img.Title"
                                        Class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-110" />
                        
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all flex flex-col justify-end p-4">
                            <p class="text-white text-[8px] font-black uppercase tracking-widest line-clamp-1">@img.Title</p>
                            <div class="mt-2 flex gap-1.5">
                                <button @onclick="() => HandleDeleteImage(img.Id)" class="h-8 w-8 rounded-lg bg-white/20 backdrop-blur-md text-white border border-white/20 hover:bg-red-500 hover:border-red-500 transition-all flex items-center justify-center">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="py-32 text-center space-y-8 bg-slate-50/50 rounded-[4rem] border-4 border-dashed border-slate-100">
                <div class="h-24 w-24 bg-white rounded-full flex items-center justify-center text-slate-200 mx-auto shadow-sm">
                    <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <div class="space-y-2">
                    <h4 class="text-xl font-black text-slate-900 italic">Static Silence.</h4>
                    <p class="text-slate-400 font-bold uppercase tracking-widest text-[10px]">No visual assets captured for this category yet.</p>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal: Category Editor -->
@if (IsCategoryModalOpen)
{
    <div class="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-[400] flex items-center justify-center p-4" @onclick="CloseCategoryModal">
        <div class="bg-white rounded-2xl w-full max-w-md p-8 space-y-8 shadow-2xl animate-in zoom-in-95 duration-300" @onclick:stopPropagation="true">
            <div class="space-y-1">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight">Category Setup</h3>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Define a new narrative segment.</p>
            </div>
            
            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest pl-1">Category Name</label>
                    <input type="text" @bind="EditingCategory.Name" class="w-full px-4 py-3 bg-slate-50 border-2 border-transparent rounded-xl focus:bg-white focus:border-purple-600 outline-none transition-all text-sm font-bold" placeholder="e.g. Clinical Labs" />
                </div>
                <div class="space-y-2">
                    <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest pl-1">Display Priority</label>
                    <input type="number" @bind="EditingCategory.DisplayOrder" class="w-full px-4 py-3 bg-slate-50 border-2 border-transparent rounded-xl focus:bg-white focus:border-purple-600 outline-none transition-all text-sm font-bold" />
                </div>
            </div>

            <div class="flex gap-3">
                <button @onclick="CloseCategoryModal" class="flex-1 py-3 bg-white text-slate-400 font-black text-[10px] uppercase tracking-widest rounded-xl border border-slate-100">Discard</button>
                <button @onclick="SaveCategory" class="flex-1 py-3 bg-slate-950 text-white font-black text-[10px] uppercase tracking-widest rounded-xl shadow-xl hover:bg-purple-600 transition-all">Synchronize</button>
            </div>
        </div>
    </div>
}

<!-- Modal: Image Uploader -->
@if (IsImageModalOpen)
{
    <div class="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-[400] flex items-center justify-center p-4" @onclick="CloseImageModal">
        <div class="bg-white rounded-2xl w-full max-w-xl p-8 space-y-8 shadow-2xl animate-in zoom-in-95 duration-300" @onclick:stopPropagation="true">
            <div class="space-y-1 text-center">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight">Expand Registry</h3>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Select an asset from the vault.</p>
            </div>
            
            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest pl-1">Target Category</label>
                    <select @bind="NewImage.GalleryCategoryId" class="w-full px-4 py-3 bg-slate-50 border-2 border-transparent rounded-xl focus:bg-white focus:border-purple-600 outline-none transition-all text-sm font-bold">
                        <option value="">Select Category</option>
                        @foreach(var cat in Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                
                <div class="space-y-2">
                    <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest pl-1">Asset Title</label>
                    <input type="text" @bind="NewImage.Title" class="w-full px-4 py-3 bg-slate-50 border-2 border-transparent rounded-xl focus:bg-white focus:border-purple-600 outline-none transition-all text-sm font-bold" placeholder="e.g. Clinical Training 2024" />
                </div>

                <MediaPicker Label="Gallery Asset" @bind-SelectedMedia="SelectedMedia" />
            </div>

            <div class="grid grid-cols-2 gap-3">
                <button @onclick="CloseImageModal" class="py-3 bg-white text-slate-400 font-black text-[10px] uppercase tracking-widest rounded-xl border border-slate-100">Discard</button>
                <button @onclick="SaveImage" disabled="@(NewImage.GalleryCategoryId == 0 || SelectedMedia == null)" class="py-3 bg-slate-950 text-white font-black text-[10px] uppercase tracking-widest rounded-xl shadow-xl hover:bg-purple-600 transition-all disabled:opacity-30 disabled:cursor-not-allowed">Integrate Asset</button>
            </div>
        </div>
    </div>
}

@code {
    private List<GalleryCategory> Categories { get; set; } = new();
    private List<GalleryImage> Images { get; set; } = new();
    private long SelectedCategoryId { get; set; } = 0;
    private bool IsLoading { get; set; } = true;

    // Category Modal
    private bool IsCategoryModalOpen { get; set; } = false;
    private GalleryCategory EditingCategory { get; set; } = new();

    // Image Modal
    private bool IsImageModalOpen { get; set; } = false;
    private GalleryImage NewImage { get; set; } = new();
    private Media? SelectedMedia { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        try 
        {
            Categories = await GalleryService.GetAllCategoriesAsync();
            await LoadImages();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadImages()
    {
        if (SelectedCategoryId == 0)
        {
            Images = await GalleryService.GetRecentImagesAsync(24);
        }
        else
        {
            Images = await GalleryService.GetImagesByCategoryAsync(SelectedCategoryId);
        }
    }

    private async Task SelectCategory(long id)
    {
        SelectedCategoryId = id;
        await LoadImages();
    }

    // Category Actions
    private void OpenCategoryModal(GalleryCategory? cat = null)
    {
        EditingCategory = cat != null ? new GalleryCategory { Id = cat.Id, Name = cat.Name, DisplayOrder = cat.DisplayOrder } : new GalleryCategory();
        IsCategoryModalOpen = true;
    }

    private void CloseCategoryModal() => IsCategoryModalOpen = false;

    private async Task SaveCategory()
    {
        if (await GalleryService.UpsertCategoryAsync(EditingCategory))
        {
            await LoadData();
            CloseCategoryModal();
        }
    }

    private async Task HandleDeleteCategory(long id)
    {
        if (await GalleryService.DeleteCategoryAsync(id))
        {
            await LoadData();
        }
    }

    // Image Actions
    private void OpenImageUploader()
    {
        NewImage = new GalleryImage { GalleryCategoryId = SelectedCategoryId > 0 ? SelectedCategoryId : 0 };
        SelectedMedia = null;
        IsImageModalOpen = true;
    }

    private void CloseImageModal() => IsImageModalOpen = false;

    private async Task SaveImage()
    {
        if (SelectedMedia == null) return;
        NewImage.MediaId = SelectedMedia.Id;
        
        if (await GalleryService.AddImageToGalleryAsync(NewImage))
        {
            await LoadImages();
            CloseImageModal();
        }
    }

    private async Task HandleDeleteImage(long id)
    {
        if (await GalleryService.DeleteImageAsync(id))
        {
            await LoadImages();
        }
    }
}
