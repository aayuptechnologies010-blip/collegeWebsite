@page "/admin/settings/hero"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Domain.Entities
@using CollegeWebSite.Domain.Enums
@using CollegeWebSite.Services.Interfaces
@attribute [AllowAnonymous]
@layout AdminLayout
@inject IHeroService HeroService
@inject IMediaService MediaService
@inject NavigationManager Nav
@inject ILogger<HeroSettings> Logger

<PageTitle>Hero Configuration | Ishika Admin</PageTitle>

<div class="mb-6 flex flex-col lg:flex-row lg:items-end justify-between gap-4 animate-in fade-in slide-in-from-top-4 duration-500">
    <div class="space-y-1">
        <div class="inline-flex items-center gap-2 px-2 py-0.5 bg-slate-900 text-white text-[8px] font-black uppercase tracking-widest rounded border border-white/10 shadow-sm">
            Landing Optimization
        </div>
        <h1 class="text-2xl font-black text-slate-900 tracking-tight leading-none uppercase">Hero <span class="text-slate-400">Section</span></h1>
    </div>

    <div class="flex items-center gap-3">
        <button @onclick="HandleSave" disabled="@IsSaving" class="px-6 py-2.5 bg-primary text-white text-xs font-black uppercase tracking-widest rounded-xl shadow-lg shadow-primary/20 hover:-translate-y-0.5 active:scale-95 transition-all flex items-center gap-2 disabled:opacity-50">
            @if (IsSaving)
            {
                <span class="h-3 w-3 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                <span>Saving...</span>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                <span>Commit Changes</span>
            }
        </button>
    </div>
</div>

@if (ShowSuccess)
{
    <div class="mb-6 p-4 bg-green-50 border border-green-100 rounded-2xl flex items-center gap-3 animate-in fade-in zoom-in slide-in-from-top-2 duration-300">
        <div class="h-8 w-8 bg-green-500 text-white rounded-lg flex items-center justify-center shadow-lg shadow-green-100">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
        </div>
        <div class="flex-1">
            <p class="text-xs font-black text-green-900 uppercase leading-none">Configuration Updated</p>
            <p class="text-[10px] text-green-600 font-bold uppercase tracking-wider mt-1">Changes have been deployed to the live landing page and cache flushed.</p>
        </div>
        <button @onclick="() => ShowSuccess = false" class="text-green-400 hover:text-green-600 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
}

<div class="grid gap-6 lg:grid-cols-2">
    <!-- Main Content Config -->
    <div class="space-y-6 animate-in fade-in slide-in-from-left-4 duration-700">
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M11 5H6a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2v-5M18.364 4.636a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.364-9.364z"/></svg>
                Identity & Headlines
            </h3>

            <div class="space-y-4">
                <div class="space-y-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Welcome Badge Text</label>
                    <input @bind="Hero.WelcomeBadge" type="text" placeholder="e.g. ADMISSIONS OPEN" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all" />
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                    <div class="space-y-1.5">
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Primary Headline</label>
                        <input @bind="Hero.HeadlineMain" type="text" placeholder="e.g. Crafting the Future..." class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all" />
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Shining (Italic) Headline</label>
                        <input @bind="Hero.HeadlineShine" type="text" placeholder="e.g. of Care" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all" />
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Sub-Headline Narration</label>
                    <textarea @bind="Hero.SubHeadline" rows="3" placeholder="Explain the institution value proposition..." class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all resize-none"></textarea>
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
                Call to Actions
            </h3>

            <div class="grid gap-6 sm:grid-cols-2">
                <div class="space-y-4">
                    <p class="text-[10px] font-black text-slate-900 uppercase">Primary Button</p>
                    <div class="space-y-1.5">
                        <input @bind="Hero.PrimaryButtonText" type="text" placeholder="Label" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:bg-white" />
                        <input @bind="Hero.PrimaryButtonLink" type="text" placeholder="Link (e.g. /apply)" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-500 focus:outline-none focus:bg-white" />
                    </div>
                </div>
                <div class="space-y-4">
                    <p class="text-[10px] font-black text-slate-900 uppercase">Secondary Button</p>
                    <div class="space-y-1.5">
                        <input @bind="Hero.SecondaryButtonText" type="text" placeholder="Label" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:bg-white" />
                        <input @bind="Hero.SecondaryButtonLink" type="text" placeholder="Link (e.g. /courses)" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-500 focus:outline-none focus:bg-white" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Secondary Config (Stats & Badge) -->
    <div class="space-y-6 animate-in fade-in slide-in-from-right-4 duration-700">
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                Institutional Metrics
            </h3>

            <div class="grid gap-4 sm:grid-cols-3">
                <div class="space-y-2 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <input @bind="Hero.Stat1Value" type="text" class="w-full bg-transparent text-lg font-black text-slate-900 border-none p-0 focus:ring-0" />
                    <input @bind="Hero.Stat1Label" type="text" class="w-full bg-transparent text-[8px] font-black text-slate-400 uppercase border-none p-0 focus:ring-0" />
                </div>
                <div class="space-y-2 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <input @bind="Hero.Stat2Value" type="text" class="w-full bg-transparent text-lg font-black text-secondary border-none p-0 focus:ring-0" />
                    <input @bind="Hero.Stat2Label" type="text" class="w-full bg-transparent text-[8px] font-black text-slate-400 uppercase border-none p-0 focus:ring-0" />
                </div>
                <div class="space-y-2 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <input @bind="Hero.Stat3Value" type="text" class="w-full bg-transparent text-lg font-black text-primary border-none p-0 focus:ring-0" />
                    <input @bind="Hero.Stat3Label" type="text" class="w-full bg-transparent text-[8px] font-black text-slate-400 uppercase border-none p-0 focus:ring-0" />
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                Trust Badge Configuration
            </h3>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="space-y-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Badge Status</label>
                    <input @bind="Hero.BadgeStatus" type="text" placeholder="e.g. Authentic" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:bg-white transition-all" />
                </div>
                <div class="space-y-1.5">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Badge Narrative</label>
                    <input @bind="Hero.BadgeLabel" type="text" placeholder="e.g. Govt Recognized" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:bg-white transition-all" />
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-4">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                <svg class="w-4 h-4 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                Visual Assets
            </h3>

            <!-- Dynamic Banner Preview -->
            <div class="relative group aspect-[1437/718] rounded-2xl overflow-hidden bg-slate-100 border border-slate-100">
                <img src="@Hero.BannerImagePath" alt="Banner Preview" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <button @onclick="OpenMediaModal" class="px-5 py-2 bg-white text-slate-900 text-[10px] font-black uppercase tracking-widest rounded-xl shadow-xl hover:bg-primary hover:text-white transition-all transform translate-y-2 group-hover:translate-y-0">
                        Swap Banner Asset
                    </button>
                </div>
            </div>

            <div class="pt-2">
                <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Active File Path</label>
                <div class="flex gap-2">
                    <input @bind="Hero.BannerImagePath" type="text" class="flex-1 px-3 py-2 bg-slate-50 border border-slate-100 rounded-xl text-[10px] font-bold text-slate-400 focus:outline-none" readonly />
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Media Vault Selector Modal -->
@if (IsMediaModalOpen)
{
    <div class="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-[200] flex items-center justify-center p-4 lg:p-12 animate-in fade-in duration-300">
        <div class="bg-white rounded-[2.5rem] w-full max-w-6xl h-full flex flex-col shadow-2xl overflow-hidden animate-in zoom-in-95 duration-500">
            <!-- Modal Header -->
            <div class="px-10 py-8 border-b border-slate-100 flex items-center justify-between shrink-0">
                <div class="space-y-1">
                    <p class="text-[10px] font-black text-primary uppercase tracking-[0.2em] leading-none">Vault Browser</p>
                    <h2 class="text-2xl font-black text-slate-900 uppercase">Select <span class="text-slate-400">Hero Banner</span></h2>
                </div>
                <button @onclick="CloseMediaModal" class="h-10 w-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-400 hover:text-slate-900 hover:bg-slate-100 transition-all">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>

            <!-- Asset Grid -->
            <div class="flex-1 overflow-y-auto p-10 custom-scrollbar">
                @if (IsLoadingMedia)
                {
                    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
                        @for (int i = 0; i < 10; i++)
                        {
                            <div class="aspect-square bg-slate-50 rounded-2xl animate-pulse border border-slate-100"></div>
                        }
                    </div>
                }
                else if (Images.Any())
                {
                    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
                        @foreach (var media in Images)
                        {
                            <div class="group relative aspect-square bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all overflow-hidden cursor-pointer" 
                                 @onclick="() => SelectImageAsset(media.Url)">
                                <img src="@media.Url" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="@media.AltText" />
                                <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
                                     <span class="text-[8px] font-black text-white uppercase tracking-widest bg-primary px-3 py-1 rounded-full shadow-lg">Pick Image</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="py-20 text-center space-y-4">
                        <div class="h-20 w-20 bg-slate-50 rounded-full flex items-center justify-center text-slate-200 mx-auto">
                            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                        <p class="text-xs font-black text-slate-400 uppercase tracking-widest leading-none">No images found in vault</p>
                    </div>
                }
            </div>

            <!-- Modal Footer -->
            <div class="px-10 py-6 border-t border-slate-100 bg-slate-50 flex items-center justify-between shrink-0">
                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest italic">Showing image assets only from institutional vault</p>
                <button @onclick='() => Nav.NavigateTo("/admin/media")' class="text-xs font-black text-primary uppercase tracking-widest hover:underline decoration-2 underline-offset-4">Upload New Asset First</button>
            </div>
        </div>
    </div>
}

<style>
    /* Premium Scrollbar */
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.05);
        border-radius: 20px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(0, 0, 0, 0.1);
    }
</style>

@code {
    private HeroContent Hero { get; set; } = new();
    private bool IsSaving { get; set; } = false;
    private bool ShowSuccess { get; set; } = false;

    // Media Modal State
    private bool IsMediaModalOpen { get; set; } = false;
    private bool IsLoadingMedia { get; set; } = false;
    private List<Media> Images { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("HeroSettings: Loading data...");
        var content = await HeroService.GetActiveHeroContentAsync();
        if (content != null)
        {
            Hero = content;
        }
        else
        {
            Hero = new HeroContent();
        }
    }

    private async Task OpenMediaModal()
    {
        IsMediaModalOpen = true;
        IsLoadingMedia = true;
        StateHasChanged();

        try
        {
            var allMedia = await MediaService.GetAllMediaAsync();
            Images = allMedia.Where(m => m.Type == MediaType.Image).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading media for hero selector");
        }
        finally
        {
            IsLoadingMedia = false;
            StateHasChanged();
        }
    }

    private void SelectImageAsset(string url)
    {
        Hero.BannerImagePath = url;
        IsMediaModalOpen = false;
    }

    private void CloseMediaModal() => IsMediaModalOpen = false;

    private async Task HandleSave()
    {
        IsSaving = true;
        ShowSuccess = false;
        StateHasChanged();

        try
        {
            var result = await HeroService.UpdateHeroContentAsync(Hero);
            if (result)
            {
                ShowSuccess = true;
                Logger.LogInformation("HeroSettings: Changes committed successfully.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "HeroSettings: Save error");
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }
}
