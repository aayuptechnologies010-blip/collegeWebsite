@page "/admin/notices/edit/{Id:long?}"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Components.Admin.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout AdminLayout
@inject INoticeService NoticeService
@inject NavigationManager Navigation

<PageTitle>@(Id.HasValue ? "Edit Notice" : "New Notice") | Ishika CMS Admin</PageTitle>

<div class="mb-12 flex flex-col lg:flex-row lg:items-end justify-between gap-8 animate-in fade-in slide-in-from-top-4 duration-700">
    <div class="space-y-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary/10 text-primary text-[10px] font-black uppercase tracking-widest rounded-lg border border-primary/5">
            Institutional Broadcast
        </div>
        <h1 class="text-4xl lg:text-5xl font-black text-slate-900 tracking-tight leading-none">
            @(Id.HasValue ? "Refine" : "Broadcast") <br/><span class="text-slate-400">@(Id.HasValue ? "Notice." : "Bulletin.")</span>
        </h1>
        <p class="text-slate-500 font-medium max-w-xl">Publish and manage critical campus announcements, holiday notices, and academic directives.</p>
    </div>
    
    <div class="flex items-center gap-4">
        <button @onclick='() => Navigation.NavigateTo("/admin/notices")' class="px-8 py-4 bg-white text-slate-500 font-black text-xs uppercase tracking-[0.2em] rounded-2xl border border-slate-100 hover:bg-slate-50 transition-all shadow-sm">
            Discard
        </button>
        <button @onclick="HandleSave" disabled="@IsSaving" class="group/btn relative px-10 py-4 bg-slate-950 text-white font-black text-xs uppercase tracking-[0.2em] rounded-2xl shadow-2xl hover:bg-primary transition-all overflow-hidden flex items-center gap-3">
             @if (IsSaving) { <div class="h-4 w-4 border-2 border-white border-t-transparent animate-spin rounded-full"></div> }
             else { <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7" /></svg> }
             Synchronize Bulletin
        </button>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Left Column: Media -->
    <div class="lg:col-span-1 space-y-10 animate-in fade-in slide-in-from-left-8 duration-700 delay-100">

        
        <div class="bg-slate-900 rounded-[3rem] p-10 text-white space-y-8">
             <div class="flex items-center gap-4">
                 <div class="h-12 w-12 rounded-2xl bg-white/10 flex items-center justify-center text-primary">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                </div>
                <h4 class="text-lg font-black tracking-tight">Broadcast Control</h4>
             </div>
             
             <div class="space-y-6">
                 <div class="flex items-center justify-between p-6 rounded-2xl bg-white/5 border border-white/10">
                     <div class="space-y-1">
                         <p class="text-xs font-black uppercase tracking-widest">Active Status</p>
                         <p class="text-[10px] text-slate-500">Visible on the notice board</p>
                     </div>
                     <input type="checkbox" @bind="Notice.IsActive" class="w-6 h-6 rounded-lg bg-slate-800 border-white/20 text-primary focus:ring-primary focus:ring-offset-slate-900" />
                 </div>

             </div>
        </div>
    </div>

    <!-- Right Column: Details -->
    <div class="lg:col-span-2 bg-white rounded-[4rem] p-12 lg:p-20 border border-slate-100 shadow-premium animate-in fade-in slide-in-from-right-8 duration-700 delay-200">
        <div class="space-y-12">
            <!-- Notice Content -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Directives & Narratives</h3>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Bulletin Headline</label>
                    <input type="text" @bind="Notice.Title" placeholder="Revised Clinical Schedule for GNM 2nd Year" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-primary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                </div>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Explanatory Narrative</label>
                    <textarea @bind="Notice.Content" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-3xl focus:bg-white focus:border-primary outline-none transition-all text-sm font-light min-h-[250px] leading-relaxed" placeholder="Detail the announcement, providing context and specific instructions for faculty or students..."></textarea>
                </div>
            </div>


        </div>
    </div>
</div>

@code {
    [Parameter] public long? Id { get; set; }
    private CampusNotice Notice { get; set; } = new() { IsActive = true };
    private bool IsSaving { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var existing = await NoticeService.GetNoticeByIdAsync(Id.Value);
            if (existing != null) Notice = existing;
        }
    }

    private async Task HandleSave()
    {
        IsSaving = true;
        try 
        {

            
            if (await NoticeService.UpsertNoticeAsync(Notice))
            {
                Navigation.NavigateTo("/admin/notices");
            }
        }
        finally
        {
            IsSaving = false;
        }
    }
}
