@page "/admin/faculty/edit/{Id:long?}"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Components.Admin.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout AdminLayout
@inject IFacultyService FacultyService
@inject NavigationManager Navigation

<PageTitle>@(Id.HasValue ? "Edit Faculty" : "New Faculty") | Ishika CMS Admin</PageTitle>

<div class="mb-12 flex flex-col lg:flex-row lg:items-end justify-between gap-8 animate-in fade-in slide-in-from-top-4 duration-700">
    <div class="space-y-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary/10 text-primary text-[10px] font-black uppercase tracking-widest rounded-lg border border-primary/5">
            Personnel Governance
        </div>
        <h1 class="text-4xl lg:text-5xl font-black text-slate-900 tracking-tight leading-none">
            @(Id.HasValue ? "Refine" : "Onboard") <br/><span class="text-slate-400">@(Id.HasValue ? "Profile." : "Faculty.")</span>
        </h1>
        <p class="text-slate-500 font-medium max-w-xl">Configure administrative and clinical profiles for the academic roster.</p>
    </div>
    
    <div class="flex items-center gap-4">
        <button @onclick='() => Navigation.NavigateTo("/admin/faculty")' class="px-8 py-4 bg-white text-slate-500 font-black text-xs uppercase tracking-[0.2em] rounded-2xl border border-slate-100 hover:bg-slate-50 transition-all shadow-sm">
            Discard
        </button>
        <button @onclick="HandleSave" disabled="@IsSaving" class="group/btn relative px-10 py-4 bg-slate-950 text-white font-black text-xs uppercase tracking-[0.2em] rounded-2xl shadow-2xl hover:bg-primary transition-all overflow-hidden flex items-center gap-3">
             @if (IsSaving) { <div class="h-4 w-4 border-2 border-white border-t-transparent animate-spin rounded-full"></div> }
             else { <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7" /></svg> }
             Synchronize Profile
        </button>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Left Column: Media -->
    <div class="lg:col-span-1 space-y-10 animate-in fade-in slide-in-from-left-8 duration-700 delay-100">
        <div class="bg-white rounded-[3rem] p-10 border border-slate-100 shadow-premium space-y-8">
            <h3 class="text-xl font-black text-slate-900 tracking-tight">Institutional Portrait</h3>
            <MediaPicker Label="Faculty Headshot" @bind-SelectedMedia="FacultyMember.Photo" />
            <p class="text-[10px] font-bold text-slate-400 uppercase leading-relaxed">Ensure high-resolution clinical attire portraits for a professional institutional appearance.</p>
        </div>
        
        <div class="bg-slate-900 rounded-[3rem] p-10 text-white space-y-6">
            <div class="h-12 w-12 rounded-2xl bg-white/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <h4 class="text-lg font-black tracking-tight">Governance Note</h4>
            <p class="text-slate-400 text-xs font-medium leading-relaxed italic">"Profiles are visible to the public. Verify clinical credentials and designations before synchronization."</p>
        </div>
    </div>

    <!-- Right Column: Details -->
    <div class="lg:col-span-2 bg-white rounded-[4rem] p-12 lg:p-20 border border-slate-100 shadow-premium animate-in fade-in slide-in-from-right-8 duration-700 delay-200">
        <div class="space-y-12">
            <!-- Identity -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Primary Identity</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Full Name</label>
                        <input type="text" @bind="FacultyMember.Name" placeholder="Dr. Sarah Johnson" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-primary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Designation</label>
                        <input type="text" @bind="FacultyMember.Designation" placeholder="Senior Clinical Tutor" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-primary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Qualification</label>
                        <input type="text" @bind="FacultyMember.Qualification" placeholder="M.Sc. Nursing, Ph.D." class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-primary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Display Priority</label>
                        <input type="number" @bind="FacultyMember.DisplayOrder" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-primary outline-none transition-all text-sm font-bold" />
                    </div>
                </div>
            </div>

            <!-- Contact -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Institutional Access</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Clinical Email</label>
                        <input type="email" @bind="FacultyMember.Email" placeholder="sarah.j@ishikanursing.in" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-primary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Direct Extension / Phone</label>
                        <input type="text" @bind="FacultyMember.PhoneNumber" placeholder="+91 000-000-0000" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-primary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                </div>
            </div>

            <!-- Bio -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Professional Narrative</h3>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Academic & Clinical Biography</label>
                    <textarea @bind="FacultyMember.Bio" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-3xl focus:bg-white focus:border-primary outline-none transition-all text-sm font-light min-h-[150px] leading-relaxed" placeholder="Describe clinical expertise, research focus, and academic contributions..."></textarea>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public long? Id { get; set; }
    private CollegeWebSite.Domain.Entities.Faculty FacultyMember { get; set; } = new();
    private bool IsSaving { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var existing = await FacultyService.GetFacultyByIdAsync(Id.Value);
            if (existing != null) FacultyMember = existing;
        }
    }

    private async Task HandleSave()
    {
        IsSaving = true;
        try 
        {
            // Sync Media ID
            FacultyMember.PhotoMediaId = FacultyMember.Photo?.Id;
            
            if (await FacultyService.UpsertFacultyAsync(FacultyMember))
            {
                Navigation.NavigateTo("/admin/faculty");
            }
        }
        finally
        {
            IsSaving = false;
        }
    }
}
