@page "/admin/popups/create"
@page "/admin/popups/edit/{Id:long}"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Domain.Entities
@using CollegeWebSite.Domain.Enums
@using CollegeWebSite.Services.Interfaces
@attribute [AllowAnonymous]
@layout AdminLayout
@inject IPopupService PopupService
@inject IMediaService MediaService
@inject NavigationManager Nav
@inject ILogger<PopupEditor> Logger

<PageTitle>@(IsEdit ? "Edit Protocol" : "New Announcement") | Ishika Admin</PageTitle>

<div class="mb-8 flex flex-col lg:flex-row lg:items-end justify-between gap-4 animate-in fade-in slide-in-from-top-4 duration-500">
    <div class="space-y-1">
        <div class="inline-flex items-center gap-2 px-2 py-0.5 bg-slate-900 text-white text-[8px] font-black uppercase tracking-widest rounded border border-white/10 shadow-sm">
            Announcement Blueprint
        </div>
        <h1 class="text-2xl font-black text-slate-900 tracking-tight leading-none uppercase">@(IsEdit ? "Update" : "Construct") <span class="text-slate-400">PopUp</span></h1>
    </div>

    <div class="flex items-center gap-3">
        <button @onclick="HandleSave" disabled="@IsSaving" class="px-6 py-2.5 bg-primary text-white text-xs font-black uppercase tracking-widest rounded-xl shadow-lg shadow-primary/20 hover:-translate-y-0.5 active:scale-95 transition-all flex items-center gap-2 disabled:opacity-50">
            @if (IsSaving)
            {
                <span class="h-3 w-3 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                <span>Saving...</span>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                <span>Commit Protocol</span>
            }
        </button>
    </div>
</div>

<div class="grid gap-8 lg:grid-cols-12 pb-20">
    <!-- Left Column: Content & Visuals -->
    <div class="lg:col-span-7 space-y-6">
        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm space-y-8">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M11 5H6a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2v-5M18.364 4.636a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.364-9.364z"/></svg>
                Communication Narrative
            </h3>
            
            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Primary Title</label>
                    <input @bind="Popup.Title" type="text" placeholder="e.g. Admission Alert 2025" class="w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-sm font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all shadow-sm" />
                </div>

                <div class="space-y-2">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Rich Description (HTML Supported)</label>
                    <textarea @bind="Popup.ContentHtml" rows="6" placeholder="Your announcement details here..." class="w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl text-sm font-medium text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:bg-white transition-all shadow-sm"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Icon Name (Lucide)</label>
                        <input @bind="Popup.IconName" type="text" placeholder="e.g. bell, info, alert" class="w-full px-5 py-3 bg-slate-50 border border-slate-100 rounded-2xl text-xs font-bold text-slate-900 focus:outline-none focus:bg-white" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Popup Type</label>
                        <select @bind="Popup.Type" class="w-full px-5 py-3 bg-slate-50 border border-slate-100 rounded-2xl text-xs font-bold text-slate-900 focus:outline-none focus:bg-white">
                            @foreach (var type in Enum.GetValues<PopUpType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm space-y-8">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
                CTA Interaction
            </h3>

            <div class="grid gap-8 md:grid-cols-2">
                <div class="space-y-4">
                    <p class="text-[10px] font-black text-slate-900 uppercase">Primary Button</p>
                    <div class="space-y-2">
                        <input @bind="Popup.PrimaryButtonText" type="text" placeholder="e.g. Apply Now" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:bg-white transition-all shadow-sm" />
                        <input @bind="Popup.PrimaryButtonUrl" type="text" placeholder="URL e.g. /apply" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-400 focus:outline-none focus:bg-white transition-all shadow-sm" />
                    </div>
                </div>
                <div class="space-y-4">
                    <p class="text-[10px] font-black text-slate-900 uppercase">Secondary Button</p>
                    <div class="space-y-2">
                        <input @bind="Popup.SecondaryButtonText" type="text" placeholder="e.g. Close" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-900 focus:outline-none focus:bg-white transition-all shadow-sm" />
                        <input @bind="Popup.SecondaryButtonUrl" type="text" placeholder="URL (optional)" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-400 focus:outline-none focus:bg-white transition-all shadow-sm" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Rules & Visual Asset -->
    <div class="lg:col-span-5 space-y-6">
        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm space-y-6">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Behavioral Rules
            </h3>

            <div class="space-y-6">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Priority (1-100)</label>
                        <input @bind="Popup.Priority" type="number" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-black text-slate-950 focus:outline-none focus:bg-white transition-all shadow-sm" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Delay Seconds</label>
                        <input @bind="Popup.DelaySeconds" type="number" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-black text-slate-950 focus:outline-none focus:bg-white transition-all shadow-sm" />
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Frequency Rule</label>
                    <select @bind="Popup.Frequency" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-xs font-black text-slate-950 focus:outline-none focus:bg-white transition-all shadow-sm">
                        @foreach (var freq in Enum.GetValues<PopUpFrequency>())
                        {
                            <option value="@freq">@freq</option>
                        }
                    </select>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">Start Date</label>
                        <input @bind="Popup.StartDate" type="date" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-[10px] font-black text-slate-900 focus:outline-none" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">End Date</label>
                        <input @bind="Popup.EndDate" type="date" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-[10px] font-black text-slate-900 focus:outline-none" />
                    </div>
                </div>

                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <div>
                        <p class="text-[10px] font-black text-slate-950 uppercase leading-none">Active Protocol</p>
                        <p class="text-[8px] font-bold text-slate-400 uppercase tracking-[0.1em] mt-1">If inactive, it won't show anywhere.</p>
                    </div>
                    <button @onclick="() => Popup.IsActive = !Popup.IsActive" class="h-6 w-12 @(Popup.IsActive ? "bg-primary" : "bg-slate-200") rounded-full p-1 transition-all flex @(Popup.IsActive ? "justify-end" : "justify-start") shadow-inner">
                        <div class="h-4 w-4 bg-white rounded-full shadow-md"></div>
                    </button>
                </div>
            </div>
        </div>

        <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm space-y-6">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                Institutional Vault Asset
            </h3>

            @if (!string.IsNullOrEmpty(Popup.ImageUrl))
            {
                <div class="relative group rounded-3xl overflow-hidden bg-slate-50 border border-slate-100 mb-4 shadow-sm p-2">
                    <img src="@Popup.ImageUrl" class="w-full h-auto max-h-[300px] object-contain rounded-2xl transition-transform duration-700 group-hover:scale-105" />
                    <div class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center backdrop-blur-[2px]">
                        <button @onclick="OpenMediaModal" class="px-6 py-3 bg-white text-slate-950 font-black text-[10px] uppercase tracking-[0.2em] rounded-2xl shadow-2xl hover:bg-primary hover:text-white transition-all transform translate-y-3 group-hover:translate-y-0">Redefine Asset</button>
                    </div>
                </div>
            }
            else
            {
                <button @onclick="OpenMediaModal" class="w-full aspect-video bg-slate-50 border-2 border-dashed border-slate-100 rounded-3xl flex flex-col items-center justify-center gap-4 group hover:bg-slate-100/50 transition-all">
                    <div class="h-16 w-16 bg-white rounded-full flex items-center justify-center text-slate-200 shadow group-hover:text-primary transition-colors">
                        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4"/></svg>
                    </div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Invoke Media Library</p>
                </button>
            }
        </div>
    </div>
</div>

<!-- Modal Vault Selector (Reuse from Hero) -->
@if (IsMediaModalOpen)
{
    <div class="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-[200] flex items-center justify-center p-4 lg:p-12 animate-in fade-in duration-300">
        <div class="bg-white rounded-[2.5rem] w-full max-w-6xl h-full flex flex-col shadow-2xl overflow-hidden animate-in zoom-in-95 duration-500">
            <div class="px-10 py-8 border-b border-slate-100 flex items-center justify-between shrink-0">
                <div class="space-y-1">
                    <p class="text-[10px] font-black text-primary uppercase tracking-[0.2em] leading-none">Vault Browser</p>
                    <h2 class="text-2xl font-black text-slate-900 uppercase">Select <span class="text-slate-400">Announcement Asset</span></h2>
                </div>
                <button @onclick="CloseMediaModal" class="h-10 w-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-400 hover:text-slate-900 hover:bg-slate-100 transition-all">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto p-10 custom-scrollbar">
                @if (IsLoadingMedia)
                {
                    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
                        @for (int i = 0; i < 10; i++)
                        {
                            <div class="aspect-square bg-slate-50 rounded-2xl animate-pulse border border-slate-100"></div>
                        }
                    </div>
                }
                else if (Images.Any())
                {
                    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
                        @foreach (var media in Images)
                        {
                            <div class="group relative aspect-square bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all overflow-hidden cursor-pointer" 
                                 @onclick="() => SelectImageAsset(media.Url)">
                                <img src="@media.Url" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="@media.AltText" />
                                <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
                                     <span class="text-[8px] font-black text-white uppercase tracking-widest bg-primary px-3 py-1 rounded-full shadow-lg">Attach Asset</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.05); border-radius: 20px; }
</style>

@code {
    [Parameter] public long? Id { get; set; }
    private AnnouncementPopUp Popup { get; set; } = new();
    private bool IsSaving { get; set; } = false;
    private bool IsEdit => Id.HasValue;

    // Media Modal
    private bool IsMediaModalOpen { get; set; } = false;
    private bool IsLoadingMedia { get; set; } = false;
    private List<Media> Images { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            var p = await PopupService.GetPopupByIdAsync(Id!.Value);
            if (p != null) Popup = p;
        }
    }

    private async Task OpenMediaModal()
    {
        IsMediaModalOpen = true;
        IsLoadingMedia = true;
        StateHasChanged();
        var all = await MediaService.GetAllMediaAsync();
        Images = all.Where(m => m.Type == MediaType.Image).ToList();
        IsLoadingMedia = false;
    }
    
    private void SelectImageAsset(string url) { Popup.ImageUrl = url; IsMediaModalOpen = false; }
    private void CloseMediaModal() => IsMediaModalOpen = false;

    private async Task HandleSave()
    {
        IsSaving = true;
        try
        {
            bool success = IsEdit 
                ? await PopupService.UpdatePopupAsync(Popup)
                : await CreateNewPopup();

            if (success) Nav.NavigateTo("/admin/popups");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving popup protocol");
        }
        finally { IsSaving = false; }
    }

    private async Task<bool> CreateNewPopup()
    {
        return await PopupService.CreatePopupAsync(Popup);
    }
}
