@page "/admin/results"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout AdminLayout
@inject IResultService ResultService
@inject NavigationManager Navigation

<PageTitle>Result Management | Ishika CMS Admin</PageTitle>

<div class="mb-8 flex flex-col lg:flex-row lg:items-end justify-between gap-4">
    <div class="space-y-2">
        <div class="inline-flex items-center gap-2 px-2.5 py-1 bg-secondary/10 text-secondary text-[9px] font-black uppercase tracking-widest rounded-md border border-secondary/5">
            Academic Performance Registry
        </div>
        <h1 class="text-3xl lg:text-4xl font-black text-slate-900 tracking-tight leading-none">Institutional <br/><span class="text-slate-400">Score Registry.</span></h1>
        <p class="text-slate-500 font-medium text-sm max-w-xl">Manage student academic performance and official examination outcomes.</p>
    </div>
    
    <button @onclick='() => Navigation.NavigateTo("/admin/results/edit")' class="group/btn relative px-8 py-3 bg-slate-950 text-white font-black text-[10px] uppercase tracking-[0.2em] rounded-xl shadow-2xl hover:bg-secondary transition-all overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/10 to-white/0 -translate-x-full group-hover/btn:animate-shimmer"></div>
        <div class="relative flex items-center gap-2">
            <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M12 4v16m8-8H4" /></svg>
            Register Student Result
        </div>
    </button>
</div>

<!-- Performance Metrics Bar -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm group hover:border-secondary/20 transition-all">
        <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mb-1.5">Total Records</p>
        <div class="flex items-end justify-between">
            <p class="text-xl font-black text-slate-900">@Results.Count</p>
            <div class="h-8 w-8 bg-slate-50 rounded-lg flex items-center justify-center text-slate-400"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div>
        </div>
    </div>
    <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm group hover:border-green-200 transition-all">
        <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mb-1.5">Pass Rate</p>
        <div class="flex items-end justify-between">
            <p class="text-xl font-black text-green-600">@(Results.Any() ? Math.Round((double)Results.Count(r => r.ResultStatus == "Pass") / Results.Count * 100, 1) : 0)%</p>
            <div class="h-8 w-8 bg-green-50 rounded-lg flex items-center justify-center text-green-600"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
        </div>
    </div>
    <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm group hover:border-blue-200 transition-all">
        <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mb-1.5">Avg. Score</p>
        <div class="flex items-end justify-between">
            <p class="text-xl font-black text-blue-600">@(Results.Any() ? Math.Round(Results.Average(r => r.TotalPercentage), 1) : 0)%</p>
            <div class="h-8 w-8 bg-blue-50 rounded-lg flex items-center justify-center text-blue-600"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg></div>
        </div>
    </div>
    <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm group hover:border-amber-200 transition-all">
        <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mb-1.5">Published</p>
        <div class="flex items-end justify-between">
            <p class="text-xl font-black text-amber-600">@Results.Count(r => r.IsPublished)</p>
            <div class="h-8 w-8 bg-amber-50 rounded-lg flex items-center justify-center text-amber-600"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></div>
        </div>
    </div>
</div>

<!-- Results Table Area -->
<div class="bg-white rounded-3xl border border-slate-100 shadow-premium overflow-hidden">
    <div class="overflow-x-auto overflow-y-visible">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50/50">
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Identity & Credentials</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Examination Track</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Performance Index</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Ledger Status</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 text-right">Actions Control</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @if (IsLoading)
                {
                    @for(int i=0; i<3; i++)
                    {
                        <tr>
                            <td colspan="5" class="px-10 py-16 animate-pulse">
                                <div class="h-8 bg-slate-50 rounded-2xl w-full"></div>
                            </td>
                        </tr>
                    }
                }
                else if (Results.Any())
                {
                    @foreach (var res in Results)
                    {
                        <tr class="group hover:bg-slate-50/50 transition-all">
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="h-9 w-9 rounded-lg bg-slate-100 flex items-center justify-center shrink-0 border border-slate-200">
                                        <span class="text-sm font-black text-slate-400">@(res.StudentName.FirstOrDefault())</span>
                                    </div>
                                    <div class="space-y-0.5">
                                        <p class="font-black text-slate-900 text-base tracking-tight leading-none">@res.StudentName</p>
                                        <div class="flex items-center gap-1.5">
                                            <span class="px-1.5 py-0.5 bg-slate-900 text-white text-[7px] font-black uppercase tracking-widest rounded leading-none">@res.RollNumber</span>
                                            <span class="text-[8px] font-bold text-slate-300 uppercase">Batch @res.Batch</span>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <div class="space-y-1.5">
                                    <p class="text-xs font-black text-slate-700 leading-none">@res.ExamName</p>
                                    <div class="inline-flex items-center gap-1.5 px-2 py-0.5 bg-white rounded-md border border-slate-100 group-hover:border-secondary/20 transition-colors">
                                        <div class="w-1 h-1 rounded-full bg-secondary shadow-[0_0_8px_rgba(var(--secondary-rgb),0.4)]"></div>
                                        <span class="text-[8px] font-black text-slate-500 uppercase tracking-widest">@res.Course</span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-6">
                                    <div class="text-center">
                                        <p class="text-[8px] font-black text-slate-300 uppercase tracking-widest mb-0.5">Grade</p>
                                        <p class="text-lg font-black text-secondary leading-none">@res.Grade</p>
                                    </div>
                                    <div class="h-6 w-[1px] bg-slate-100"></div>
                                    <div class="text-center">
                                        <p class="text-[8px] font-black text-slate-300 uppercase tracking-widest mb-0.5">Score</p>
                                        <p class="text-lg font-black text-slate-900 leading-none">@res.TotalPercentage<span class="text-slate-300 text-[10px]">%</span></p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-3">
                                     @if (res.IsPublished)
                                     {
                                         <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-50 text-green-600 text-[8px] font-black uppercase tracking-[0.15em] border border-green-100">
                                             <span class="h-1 w-1 rounded-full bg-green-600 animate-pulse"></span>
                                             Active
                                         </span>
                                     }
                                     else
                                     {
                                         <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-slate-100 text-slate-400 text-[8px] font-black uppercase tracking-[0.15em] border border-slate-200">
                                             Draft
                                         </span>
                                     }
                                     
                                     @if (res.ResultStatus == "Pass")
                                     {
                                         <div class="p-1 rounded-full bg-green-50 text-green-600 border border-green-100" title="Examination Status: PASS">
                                             <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7" /></svg>
                                         </div>
                                     }
                                </div>
                            </td>
                            <td class="px-8 py-5 text-right">
                                <div class="flex items-center justify-end gap-2 lg:translate-x-2 lg:opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-500">
                                     <button @onclick='() => Navigation.NavigateTo($"/admin/results/edit/{res.Id}")' class="h-9 w-9 rounded-xl bg-white border border-slate-100 text-slate-400 hover:text-secondary hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center justify-center">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                                    </button>
                                    <button @onclick="() => HandleDelete(res.Id)" class="h-9 w-9 rounded-xl bg-white border border-slate-100 text-slate-400 hover:text-red-500 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center justify-center">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="py-40 text-center">
                            <div class="h-24 w-24 bg-slate-50 rounded-[2rem] flex items-center justify-center text-slate-200 mx-auto mb-6">
                                <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            </div>
                            <h4 class="text-xl font-black text-slate-900 mb-2">Vault is Empty.</h4>
                            <p class="text-slate-400 font-bold uppercase tracking-widest text-[10px]">No institutional student scores have been registered yet.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    @@keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }
    .animate-shimmer {
        animation: shimmer 2s infinite;
    }
</style>

@code {
    private List<StudentResult> Results { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadResults();
    }

    private async Task LoadResults()
    {
        try 
        {
            await Task.Delay(500); // Aesthetic delay
            Results = await ResultService.GetAllResultsAsync();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleDelete(long id)
    {
        if (await ResultService.DeleteResultAsync(id))
        {
            await LoadResults();
        }
    }
}
