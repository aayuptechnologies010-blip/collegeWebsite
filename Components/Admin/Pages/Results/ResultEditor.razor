@page "/admin/results/edit/{Id:long?}"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Components.Admin.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout AdminLayout
@inject IResultService ResultService
@inject NavigationManager Navigation

<PageTitle>@(Id.HasValue ? "Edit Result" : "New Result") | Ishika CMS Admin</PageTitle>

<div class="mb-12 flex flex-col lg:flex-row lg:items-end justify-between gap-8 animate-in fade-in slide-in-from-top-4 duration-700">
    <div class="space-y-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-secondary/10 text-secondary text-[10px] font-black uppercase tracking-widest rounded-lg border border-secondary/5">
            Academic Performance
        </div>
        <h1 class="text-4xl lg:text-5xl font-black text-slate-900 tracking-tight leading-none">
            @(Id.HasValue ? "Refine" : "Register") <br/><span class="text-slate-400">@(Id.HasValue ? "Score." : "Result.")</span>
        </h1>
        <p class="text-slate-500 font-medium max-w-xl">Centralized entry for institutional scorecards, grade-sheets, and official performance indices.</p>
    </div>
    
    <div class="flex items-center gap-4">
        <button @onclick='() => Navigation.NavigateTo("/admin/results")' class="px-8 py-4 bg-white text-slate-500 font-black text-xs uppercase tracking-[0.2em] rounded-2xl border border-slate-100 hover:bg-slate-50 transition-all shadow-sm">
            Discard
        </button>
        <button @onclick="HandleSave" disabled="@IsSaving" class="group/btn relative px-10 py-4 bg-slate-950 text-white font-black text-xs uppercase tracking-[0.2em] rounded-2xl shadow-2xl hover:bg-secondary transition-all overflow-hidden flex items-center gap-3">
             @if (IsSaving) { <div class="h-4 w-4 border-2 border-white border-t-transparent animate-spin rounded-full"></div> }
             else { <svg class="w-5 h-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7" /></svg> }
             Synchronize Ledger
        </button>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Left Column: Media -->
    <div class="lg:col-span-1 space-y-10 animate-in fade-in slide-in-from-left-8 duration-700 delay-100">
        <div class="bg-white rounded-[3rem] p-10 border border-slate-100 shadow-premium space-y-8">
            <h3 class="text-xl font-black text-slate-900 tracking-tight text-center">Marksheet Reference</h3>
            <div class="space-y-2">
                <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest pl-1">Document URL (PDF)</label>
                <input type="text" @bind="Result.DownloadUrl" class="w-full px-4 py-3 bg-slate-50 border-2 border-transparent rounded-xl focus:bg-white focus:border-secondary outline-none transition-all text-sm font-bold" placeholder="https://..." />
            </div>
            <p class="text-[10px] font-bold text-slate-400 uppercase leading-relaxed text-center">Provide a link to the official digital marksheet for verification.</p>
        </div>
        
        <div class="bg-slate-900 rounded-[3rem] p-10 text-white space-y-8">
             <div class="flex items-center gap-4">
                 <div class="h-12 w-12 rounded-2xl bg-white/10 flex items-center justify-center text-secondary">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </div>
                <h4 class="text-lg font-black tracking-tight text-secondary">Visibility</h4>
             </div>
             
             <div class="space-y-6">
                 <div class="flex items-center justify-between p-6 rounded-2xl bg-white/5 border border-white/10">
                     <div class="space-y-1">
                         <p class="text-xs font-black uppercase tracking-widest">Publish Result</p>
                         <p class="text-[10px] text-slate-500">Accessible by student roll number</p>
                     </div>
                     <input type="checkbox" @bind="Result.IsPublished" class="w-6 h-6 rounded-lg bg-slate-800 border-white/20 text-secondary focus:ring-secondary focus:ring-offset-slate-900" />
                 </div>
             </div>
        </div>
    </div>

    <!-- Right Column: Details -->
    <div class="lg:col-span-2 bg-white rounded-[4rem] p-12 lg:p-20 border border-slate-100 shadow-premium animate-in fade-in slide-in-from-right-8 duration-700 delay-200">
        <div class="space-y-12">
            <!-- Identity -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Student Credentials</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Name of Candidate</label>
                        <input type="text" @bind="Result.StudentName" placeholder="Priyanka Das" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-secondary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Roll / Registry Number</label>
                        <input type="text" @bind="Result.RollNumber" placeholder="GNM-2023-001" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-secondary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Batch</label>
                        <input type="text" @bind="Result.Batch" placeholder="2023-2026" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-secondary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Academic Course</label>
                        <input type="text" @bind="Result.Course" placeholder="GNM Nursing" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-secondary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                </div>
            </div>

            <!-- Performance -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Performance Index</h3>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Examination Title</label>
                    <input type="text" @bind="Result.ExamName" placeholder="1st Year Annual Examination" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-secondary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Total Percentage (%)</label>
                        <input type="number" step="0.01" @bind="Result.TotalPercentage" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-secondary outline-none transition-all text-sm font-bold" />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Grade</label>
                        <input type="text" @bind="Result.Grade" placeholder="A+" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-secondary outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Outcome Status</label>
                        <select @bind="Result.ResultStatus" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-secondary outline-none transition-all text-sm font-bold">
                            <option value="Pass">Pass</option>
                            <option value="Fail">Fail</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public long? Id { get; set; }
    private StudentResult Result { get; set; } = new() { ResultStatus = "Pass" };
    private bool IsSaving { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var existing = await ResultService.GetResultByIdAsync(Id.Value);
            if (existing != null) Result = existing;
        }
    }

    private async Task HandleSave()
    {
        IsSaving = true;
        try 
        {

            
            if (await ResultService.UpsertResultAsync(Result))
            {
                Navigation.NavigateTo("/admin/results");
            }
        }
        finally
        {
            IsSaving = false;
        }
    }
}
