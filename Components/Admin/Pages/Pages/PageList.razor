@page "/admin/pages"
@using CollegeWebSite.Domain.Entities
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Components.Admin.Layout
@inject IPageService PageService
@inject NavigationManager NavManager
@layout AdminLayout

<PageTitle>Academic Pages | Ishika CMS Admin</PageTitle>

<div class="mb-8 flex flex-col lg:flex-row lg:items-end justify-between gap-4 animate-in fade-in slide-in-from-top-4 duration-700">
    <div class="space-y-2">
        <div class="inline-flex items-center gap-2 px-2.5 py-1 bg-primary/10 text-primary text-[9px] font-black uppercase tracking-widest rounded-md border border-primary/5">
            Content Governance
        </div>
        <h1 class="text-3xl lg:text-4xl font-black text-slate-900 tracking-tight leading-none">Institutional <br/><span class="text-slate-400">Content Nexus.</span></h1>
        <p class="text-slate-500 font-medium text-sm max-w-xl">Configure structural pages and academic landing hubs for the public portal.</p>
    </div>
    
    <button @onclick='() => NavManager.NavigateTo("/admin/pages/create")' class="group/btn relative px-8 py-3 bg-slate-950 text-white font-black text-[10px] uppercase tracking-[0.2em] rounded-xl shadow-2xl hover:bg-primary transition-all overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/10 to-white/0 -translate-x-full group-hover/btn:animate-shimmer"></div>
        <div class="relative flex items-center gap-2">
            <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M12 4v16m8-8H4" /></svg>
            Construct New Page
        </div>
    </button>
</div>

<div class="bg-white rounded-3xl border border-slate-100 shadow-premium overflow-hidden animate-in fade-in slide-in-from-bottom-8 duration-700 delay-200">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50/50">
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Structural Title</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Locator (Slug)</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Layout Engine</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Governing Status</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 text-right">Action Nexus</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @if (Pages == null)
                {
                    @for(int i=0; i<5; i++)
                    {
                        <tr><td colspan="5" class="px-10 py-12 animate-pulse"><div class="h-8 bg-slate-50 rounded-2xl w-full"></div></td></tr>
                    }
                }
                else if (!Pages.Any())
                {
                    <tr>
                        <td colspan="5" class="py-40 text-center">
                            <div class="h-24 w-24 bg-slate-50 rounded-[2rem] flex items-center justify-center text-slate-200 mx-auto mb-6 shadow-inner">
                                <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                            </div>
                            <h4 class="text-xl font-black text-slate-900 mb-2">Architectural Silence.</h4>
                            <p class="text-slate-400 font-bold uppercase tracking-widest text-[10px]">No institutional pages have been constructed yet.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var pageItem in Pages)
                    {
                        <tr class="group hover:bg-slate-50/50 transition-all">
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="h-9 w-9 rounded-xl bg-slate-100 flex items-center justify-center text-slate-400 font-black shadow-sm group-hover:bg-primary group-hover:text-white transition-all duration-500 text-[10px]">
                                        P
                                    </div>
                                    <div class="space-y-0.5">
                                        <p class="font-black text-slate-900 text-base tracking-tight leading-none">@pageItem.Title</p>
                                        <p class="text-[8px] font-bold text-slate-400 uppercase tracking-widest">@(pageItem.LastModifiedOn?.ToString("MMM dd, yyyy") ?? pageItem.CreatedOn.ToString("MMM dd, yyyy"))</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <span class="px-2 py-0.5 bg-slate-900 text-white text-[9px] font-bold tracking-tight rounded-md">/@pageItem.Slug</span>
                            </td>
                            <td class="px-8 py-5">
                                <div class="inline-flex items-center gap-1.5 px-2 py-0.5 bg-purple-50 text-purple-600 rounded-md border border-purple-100 transition-colors">
                                    <div class="w-1 h-1 rounded-full bg-purple-500"></div>
                                    <span class="text-[9px] font-black uppercase tracking-widest text-nowrap">@(pageItem.Template?.Name ?? "Default")</span>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                @if (pageItem.IsPublished)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-50 text-green-600 text-[8px] font-black uppercase tracking-[0.1em] border border-green-100">
                                        <span class="h-1 w-1 rounded-full bg-green-600 animate-pulse"></span>
                                        Live
                                    </span>
                                }
                                else
                                {
                                     <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-slate-100 text-slate-400 text-[8px] font-black uppercase tracking-[0.1em] border border-slate-200">
                                        Draft
                                    </span>
                                }
                            </td>
                            <td class="px-8 py-5 text-right">
                                <div class="flex items-center justify-end gap-2 lg:translate-x-2 lg:opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-500">
                                     <a href="/p/@pageItem.Slug" target="_blank" class="h-9 w-9 rounded-xl bg-white border border-slate-100 text-slate-400 hover:text-primary hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center justify-center">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    </a>
                                    <button @onclick='() => NavManager.NavigateTo($"/admin/pages/edit/{pageItem.Id}")' class="h-9 w-9 rounded-xl bg-white border border-slate-100 text-slate-400 hover:text-blue-500 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center justify-center">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                                    </button>
                                    <button @onclick="() => DeletePage(pageItem.Id)" class="h-9 w-9 rounded-xl bg-white border border-slate-100 text-slate-400 hover:text-red-500 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center justify-center">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<PageContent>? Pages { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadPages();
    }

    private async Task LoadPages()
    {
        Pages = await PageService.GetAllPagesAsync();
    }

    private async Task DeletePage(long id)
    {
        await PageService.DeletePageAsync(id);
        await LoadPages();
    }
}
