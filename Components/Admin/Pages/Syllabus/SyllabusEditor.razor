@page "/admin/syllabus/edit/{Id:long?}"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Components.Admin.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout AdminLayout
@inject ISyllabusService SyllabusService
@inject NavigationManager Navigation

<PageTitle>@(Id.HasValue ? "Edit Syllabus" : "New Syllabus") | Ishika CMS Admin</PageTitle>

<div class="mb-12 flex flex-col lg:flex-row lg:items-end justify-between gap-8 animate-in fade-in slide-in-from-top-4 duration-700">
    <div class="space-y-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-amber-50 text-amber-600 text-[10px] font-black uppercase tracking-widest rounded-lg border border-amber-100">
            Academic Governance
        </div>
        <h1 class="text-4xl lg:text-5xl font-black text-slate-900 tracking-tight leading-none">
            @(Id.HasValue ? "Refine" : "Create") <br/><span class="text-slate-400">@(Id.HasValue ? "Curriculum." : "Syllabus.")</span>
        </h1>
        <p class="text-slate-500 font-medium max-w-xl">Configure subject-wise academic plans, clinical curriculum modules, and official syllabus resources.</p>
    </div>
    
    <div class="flex items-center gap-4">
        <button @onclick='() => Navigation.NavigateTo("/admin/syllabus")' class="px-8 py-4 bg-white text-slate-500 font-black text-xs uppercase tracking-[0.2em] rounded-2xl border border-slate-100 hover:bg-slate-50 transition-all shadow-sm">
            Discard
        </button>
        <button @onclick="HandleSave" disabled="@IsSaving" class="group/btn relative px-10 py-4 bg-slate-950 text-white font-black text-xs uppercase tracking-[0.2em] rounded-2xl shadow-2xl hover:bg-amber-500 transition-all overflow-hidden flex items-center gap-3">
             @if (IsSaving) { <div class="h-4 w-4 border-2 border-white border-t-transparent animate-spin rounded-full"></div> }
             else { <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7" /></svg> }
             Synchronize Curriculum
        </button>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Left Column: Media -->
    <div class="lg:col-span-1 space-y-10 animate-in fade-in slide-in-from-left-8 duration-700 delay-100">
        <div class="bg-white rounded-[3rem] p-10 border border-slate-100 shadow-premium space-y-8">
            <h3 class="text-xl font-black text-slate-900 tracking-tight text-center">Syllabus Resource</h3>
            <MediaPicker Label="Curriculum PDF" @bind-SelectedMedia="Syllabus.DocumentMedia" />
            <p class="text-[10px] font-bold text-slate-400 uppercase leading-relaxed text-center">Attach the official institutional curriculum document for student download.</p>
        </div>
        
        <div class="bg-slate-900 rounded-[3rem] p-10 text-white space-y-8">
             <div class="flex items-center gap-4">
                 <div class="h-12 w-12 rounded-2xl bg-white/10 flex items-center justify-center text-amber-500">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                </div>
                <h4 class="text-lg font-black tracking-tight text-amber-500">Academic Track</h4>
             </div>
             
             <div class="space-y-6">
                 <div class="space-y-3">
                    <label class="text-[10px] font-black text-white/40 uppercase tracking-widest pl-1">Course Sector</label>
                    <select @bind="Syllabus.CourseName" class="w-full px-6 py-4 bg-white/5 border border-white/10 rounded-2xl focus:bg-white/10 focus:border-amber-500 outline-none transition-all text-sm font-bold text-white">
                        <option value="GNM Nursing">GNM Nursing</option>
                        <option value="ANM Nursing">ANM Nursing</option>
                        <option value="B.Sc. Nursing">B.Sc. Nursing</option>
                        <option value="Paramedical">Paramedical</option>
                    </select>
                 </div>
                 <div class="space-y-3">
                    <label class="text-[10px] font-black text-white/40 uppercase tracking-widest pl-1">Academic Year</label>
                    <input type="text" @bind="Syllabus.AcademicYear" placeholder="e.g. 1st Year" class="w-full px-6 py-4 bg-white/5 border border-white/10 rounded-2xl focus:bg-white/10 focus:border-amber-500 outline-none transition-all text-sm font-bold text-white" />
                 </div>
             </div>
        </div>
    </div>

    <!-- Right Column: Details -->
    <div class="lg:col-span-2 bg-white rounded-[4rem] p-12 lg:p-20 border border-slate-100 shadow-premium animate-in fade-in slide-in-from-right-8 duration-700 delay-200">
        <div class="space-y-12">
            <!-- Subject Info -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Curriculum Segment</h3>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Subject Title</label>
                    <input type="text" @bind="Syllabus.Subject" placeholder="Bio-Sciences (Anatomy & Physiology)" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-amber-500 outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                </div>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Curriculum Outline / Description</label>
                    <textarea @bind="Syllabus.Description" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-3xl focus:bg-white focus:border-amber-500 outline-none transition-all text-sm font-light min-h-[300px] leading-relaxed" placeholder="Detail the specific topics, clinical modules, and learning objectives for this subject..."></textarea>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public long? Id { get; set; }
    private Syllabus Syllabus { get; set; } = new() { CourseName = "GNM Nursing" };
    private bool IsSaving { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var existing = await SyllabusService.GetSyllabusByIdAsync(Id.Value);
            if (existing != null) Syllabus = existing;
        }
    }

    private async Task HandleSave()
    {
        IsSaving = true;
        try 
        {
            // Sync Media ID
            Syllabus.DocumentMediaId = Syllabus.DocumentMedia?.Id;
            
            if (await SyllabusService.UpsertSyllabusAsync(Syllabus))
            {
                Navigation.NavigateTo("/admin/syllabus");
            }
        }
        finally
        {
            IsSaving = false;
        }
    }
}
