@page "/admin"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@attribute [AllowAnonymous]
@layout AdminLayout
@inject IInquiryService InquiryService
@inject IPageService PageService
@inject IEventService EventService
@inject IMediaService MediaService
@inject NavigationManager Nav
@inject ILogger<Dashboard> Logger

<PageTitle>Executive Control | Ishika CMS Admin</PageTitle>

<div class="mb-4 flex flex-col lg:flex-row lg:items-end justify-between gap-3 animate-in fade-in slide-in-from-top-4 duration-700">

    <div class="space-y-1">
        <div class="inline-flex items-center gap-2 px-2 py-0.5 bg-slate-900 text-white text-[8px] font-black uppercase tracking-widest rounded border border-white/10 shadow-sm">
            Institutional Oversight
        </div>
        <h1 class="text-xl font-black text-slate-900 tracking-tight leading-none uppercase">Administrative <span class="text-slate-400">Hub</span></h1>
    </div>
    
    <div class="flex items-center gap-2">
        <div class="flex -space-x-2">
            <div class="h-7 w-7 rounded-full border border-white bg-slate-800 flex items-center justify-center text-[8px] font-black text-white shadow-md">A</div>
            <div class="h-7 w-7 rounded-full border border-white bg-primary flex items-center justify-center text-[8px] font-black text-white shadow-md">I</div>
        </div>
        <div class="pl-2.5 border-l border-slate-100">
            <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest leading-none mb-0.5">Status</p>
            <p class="text-[10px] font-black text-blue-500 flex items-center gap-1 uppercase leading-none">
                <span class="h-1 w-1 rounded-full bg-blue-500 animate-pulse"></span>
                Secure
            </p>
        </div>
    </div>
</div>

@if (IsLoading)
{
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        @for(int i=0; i<4; i++)
        {
            <div class="h-40 bg-white rounded-[2.5rem] border border-slate-100 animate-pulse"></div>
        }
    </div>
}
else
{
    <!-- Metrics Grid -->
    <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-4 animate-in fade-in slide-in-from-bottom-8 duration-700">
        <!-- Academic Pages -->
        <div class="bg-white p-3 rounded-lg border border-slate-100 shadow-sm group hover:bg-primary transition-all duration-500">
            <div class="flex items-center justify-between mb-1.5">
                <div class="h-7 w-7 rounded bg-primary/5 text-primary flex items-center justify-center group-hover:bg-white/20 group-hover:text-white transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                </div>
                <span class="text-[7px] font-black text-slate-300 uppercase tracking-widest group-hover:text-white/50">Structure</span>
            </div>
            <p class="text-lg font-black text-slate-900 group-hover:text-white tracking-tighter">@TotalPages</p>
            <p class="text-[7px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white/70">Pages</p>
        </div>

        <!-- Inquiries -->
        <div class="bg-white p-3 rounded-lg border border-slate-100 shadow-sm group hover:bg-red-500 transition-all duration-500">
            <div class="flex items-center justify-between mb-1.5">
                <div class="h-7 w-7 rounded bg-red-50 text-red-500 flex items-center justify-center group-hover:bg-white/20 group-hover:text-white transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <span class="text-[7px] font-black text-slate-300 uppercase tracking-widest group-hover:text-white/50">Intelligence</span>
            </div>
            <p class="text-lg font-black text-slate-900 group-hover:text-white tracking-tighter">@TotalInquiries</p>
            <p class="text-[7px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white/70">Inquiries</p>
        </div>

        <!-- Events -->
        <div class="bg-white p-3 rounded-lg border border-slate-100 shadow-sm group hover:bg-slate-900 transition-all duration-500">
            <div class="flex items-center justify-between mb-1.5">
                <div class="h-7 w-7 rounded bg-slate-50 text-slate-400 flex items-center justify-center group-hover:bg-white/20 group-hover:text-white transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <span class="text-[7px] font-black text-slate-300 uppercase tracking-widest group-hover:text-white/50">Engagement</span>
            </div>
            <p class="text-lg font-black text-slate-900 group-hover:text-white tracking-tighter">@TotalEvents</p>
            <p class="text-[7px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white/70">Events</p>
        </div>

        <!-- Media Vault -->
        <div class="bg-white p-3 rounded-lg border border-slate-100 shadow-sm group hover:bg-blue-600 transition-all duration-500">
            <div class="flex items-center justify-between mb-1.5">
                <div class="h-7 w-7 rounded bg-blue-50 text-blue-500 flex items-center justify-center group-hover:bg-white/20 group-hover:text-white transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                </div>
                <span class="text-[7px] font-black text-slate-300 uppercase tracking-widest group-hover:text-white/50">Assets</span>
            </div>
            <p class="text-lg font-black text-slate-900 group-hover:text-white tracking-tighter">@TotalMedia</p>
            <p class="text-[7px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white/70">Vault</p>
        </div>
    </div>

    <div class="mt-6 grid gap-6 lg:grid-cols-5 animate-in fade-in slide-in-from-bottom-12 duration-700 delay-200">
        <!-- Recent Narratives -->
        <div class="lg:col-span-3 space-y-4">
            <div class="flex items-center justify-between px-1">
                 <h3 class="text-lg font-black text-slate-900 tracking-tight uppercase">Recent <span class="text-slate-400">Directives</span></h3>
                 <a href="/admin/inquiries" class="text-[8px] font-black text-primary uppercase tracking-widest hover:underline px-2.5 py-1 bg-primary/5 rounded">Scan Ledger</a>
            </div>
            
            <div class="bg-white rounded-lg border border-slate-100 shadow-sm overflow-hidden divide-y divide-slate-100">
                @if (RecentInquiries.Any())
                {
                    @foreach (var inq in RecentInquiries)
                    {
                        <div class="group flex items-start gap-3 p-4 hover:bg-slate-50 transition-all cursor-pointer">
                            <div class="h-8 w-8 rounded bg-slate-900 text-white flex items-center justify-center text-[11px] font-black shadow group-hover:scale-105 transition-transform">
                                @GetInitial(inq.Name)
                            </div>
                            <div class="flex-1 min-w-0 space-y-0.5">
                                <div class="flex justify-between items-start">
                                     <h4 class="text-sm font-black text-slate-900 leading-none uppercase">@inq.Name</h4>
                                     <span class="text-[7px] font-black text-slate-300 uppercase tracking-widest">@GetTimeAgo(inq.SubmittedOn)</span>
                                </div>
                                <p class="text-[10px] text-slate-500 font-bold truncate max-w-sm">@inq.Subject</p>
                                <div class="flex items-center gap-1 pt-0.5">
                                    <span class="h-1 w-1 rounded-full bg-red-500"></span>
                                    <span class="text-[6px] font-black text-slate-400 uppercase tracking-widest">Priority Directive</span>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="p-20 text-center space-y-4">
                        <div class="h-16 w-16 bg-slate-50 rounded-[1.5rem] flex items-center justify-center text-slate-200 mx-auto">
                             <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                        </div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">No active communications found</p>
                    </div>
                }
            </div>
        </div>

        <!-- Rapid Actions -->
        <div class="lg:col-span-2 space-y-3">
            <h3 class="text-[10px] font-black text-slate-900 tracking-tight px-1 uppercase leading-none mt-1">Rapid <span class="text-slate-400">Nexus</span></h3>
            <div class="grid grid-cols-3 gap-2">
                <button @onclick='() => Nav.NavigateTo("/admin/pages/create")' class="group flex flex-col items-center justify-center p-3 rounded-lg bg-white border border-slate-100 shadow-sm hover:bg-slate-900 transition-all duration-500">
                    <div class="h-6 w-6 rounded bg-primary/5 text-primary flex items-center justify-center mb-1.5 group-hover:bg-white/20 group-hover:text-white transition-all">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M12 4v16m8-8H4" /></svg>
                    </div>
                    <span class="text-[6px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white">Pages</span>
                </button>
                
                <button @onclick='() => Nav.NavigateTo("/admin/media")' class="group flex flex-col items-center justify-center p-3 rounded-lg bg-white border border-slate-100 shadow-sm hover:bg-blue-600 transition-all duration-500">
                    <div class="h-6 w-6 rounded bg-blue-50 text-blue-600 flex items-center justify-center mb-1.5 group-hover:bg-white/20 group-hover:text-white transition-all">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                    </div>
                    <span class="text-[6px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white">Assets</span>
                </button>
                
                <button @onclick='() => Nav.NavigateTo("/admin/events/edit")' class="group flex flex-col items-center justify-center p-3 rounded-lg bg-white border border-slate-100 shadow-sm hover:bg-purple-600 transition-all duration-500">
                    <div class="h-6 w-6 rounded bg-purple-50 text-purple-600 flex items-center justify-center mb-1.5 group-hover:bg-white/20 group-hover:text-white transition-all">
                         <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                    </div>
                    <span class="text-[6px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white">Events</span>
                </button>
                
                <button @onclick='() => Nav.NavigateTo("/admin/notices/edit")' class="group flex flex-col items-center justify-center p-3 rounded-lg bg-white border border-slate-100 shadow-sm hover:bg-amber-600 transition-all duration-500">
                    <div class="h-6 w-6 rounded bg-amber-50 text-amber-600 flex items-center justify-center mb-1.5 group-hover:bg-white/20 group-hover:text-white transition-all">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                    </div>
                    <span class="text-[6px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white">Notice</span>
                </button>
                
                <button @onclick='() => Nav.NavigateTo("/admin/diagnostics/logs")' class="group flex flex-col items-center justify-center p-3 rounded-lg bg-white border border-slate-100 shadow-sm hover:bg-red-600 transition-all duration-500">
                    <div class="h-6 w-6 rounded bg-red-50 text-red-600 flex items-center justify-center mb-1.5 group-hover:bg-white/20 group-hover:text-white transition-all">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/><line x1="13" x2="13" y1="18" y2="18"/><line x1="13" x2="13" y1="14" y2="14"/></svg>
                    </div>
                    <span class="text-[6px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white">Logs</span>
                </button>
            </div>
            
            <!-- Quick Stats -->
            <div class="p-4 bg-slate-900 rounded-xl text-white space-y-3">
                <div class="flex items-center gap-2.5 border-b border-white/10 pb-3">
                     <div class="h-7 w-7 bg-white/10 rounded flex items-center justify-center text-primary"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
                     <div>
                         <p class="text-[7px] font-black text-slate-500 uppercase tracking-widest leading-none mb-0.5">Efficiency</p>
                         <p class="text-sm font-black tracking-tight leading-none uppercase">Optimized</p>
                     </div>
                </div>
                <div class="space-y-2">
                    <div class="flex justify-between items-center text-[7px] font-black uppercase tracking-widest">
                        <span>Pulse</span>
                        <span class="text-green-500">Active</span>
                    </div>
                    <div class="h-1 w-full bg-white/10 rounded-full overflow-hidden">
                        <div class="h-full w-[85%] bg-primary rounded-full"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int TotalPages { get; set; }
    private int TotalInquiries { get; set; }
    private int TotalEvents { get; set; }
    private int TotalMedia { get; set; }
    private List<Inquiry> RecentInquiries { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("[Dashboard] Initializing data...");
        try 
        {
            var pTask = PageService.GetAllPagesAsync();
            var iCountTask = InquiryService.GetTotalInquiriesCountAsync();
            var iRecentTask = InquiryService.GetRecentInquiriesAsync(4);
            var eTask = EventService.GetAllEventsAsync(false);
            var mTask = MediaService.GetTotalMediaCountAsync();

            await Task.WhenAll(pTask, iCountTask, iRecentTask, eTask, mTask);
            
            TotalPages = pTask.Result.Count;
            TotalInquiries = iCountTask.Result;
            RecentInquiries = iRecentTask.Result;
            TotalEvents = eTask.Result.Count;
            TotalMedia = mTask.Result;
            Logger.LogInformation("[Dashboard] Data initialized successfully.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[Dashboard] Error during data initialization");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string GetTimeAgo(DateTime dateTime)
    {
        var span = DateTime.UtcNow - dateTime;
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private string GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";
        return name.Trim().Substring(0, 1).ToUpper();
    }
}
