@page "/admin/placements/edit/{Id:long?}"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Components.Admin.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout AdminLayout
@inject IPlacementService PlacementService
@inject NavigationManager Navigation

<PageTitle>@(Id.HasValue ? "Edit Placement" : "New Placement") | Ishika CMS Admin</PageTitle>

<div class="mb-12 flex flex-col lg:flex-row lg:items-end justify-between gap-8 animate-in fade-in slide-in-from-top-4 duration-700">
    <div class="space-y-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-green-50 text-green-600 text-[10px] font-black uppercase tracking-widest rounded-lg border border-green-100">
            Success Narratives
        </div>
        <h1 class="text-4xl lg:text-5xl font-black text-slate-900 tracking-tight leading-none">
            @(Id.HasValue ? "Refine" : "Register") <br/><span class="text-slate-400">@(Id.HasValue ? "Record." : "Placement.")</span>
        </h1>
        <p class="text-slate-500 font-medium max-w-xl">Document institutional career milestones and celebrate student success in the healthcare industry.</p>
    </div>
    
    <div class="flex items-center gap-4">
        <button @onclick='() => Navigation.NavigateTo("/admin/placements")' class="px-8 py-4 bg-white text-slate-500 font-black text-xs uppercase tracking-[0.2em] rounded-2xl border border-slate-100 hover:bg-slate-50 transition-all shadow-sm">
            Discard
        </button>
        <button @onclick="HandleSave" disabled="@IsSaving" class="group/btn relative px-10 py-4 bg-slate-950 text-white font-black text-xs uppercase tracking-[0.2em] rounded-2xl shadow-2xl hover:bg-green-600 transition-all overflow-hidden flex items-center gap-3">
             @if (IsSaving) { <div class="h-4 w-4 border-2 border-white border-t-transparent animate-spin rounded-full"></div> }
             else { <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7" /></svg> }
             Synchronize Milestone
        </button>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Left Column: Portrait -->
    <div class="lg:col-span-1 space-y-10 animate-in fade-in slide-in-from-left-8 duration-700 delay-100">
        <div class="bg-white rounded-[3rem] p-10 border border-slate-100 shadow-premium space-y-8">
            <h3 class="text-xl font-black text-slate-900 tracking-tight">Success Portrait</h3>
            <MediaPicker Label="Student Photo" @bind-SelectedMedia="Placement.StudentPhoto" />
            <p class="text-[10px] font-bold text-slate-400 uppercase leading-relaxed">High-fidelity graduation or clinical portraits reinforce the institution's professional legacy.</p>
        </div>
        
        <div class="bg-slate-900 rounded-[3rem] p-10 text-white space-y-8">
             <div class="flex items-center gap-4">
                 <div class="h-12 w-12 rounded-2xl bg-white/10 flex items-center justify-center text-green-400">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <h4 class="text-lg font-black tracking-tight">Highlighting</h4>
             </div>
             
             <div class="space-y-6">
                 <div class="flex items-center justify-between p-6 rounded-2xl bg-white/5 border border-white/10">
                     <div class="space-y-1">
                         <p class="text-xs font-black uppercase tracking-widest text-green-400">Featured Placement</p>
                         <p class="text-[10px] text-slate-500">Display on home success reel</p>
                     </div>
                     <input type="checkbox" @bind="Placement.IsFeatured" class="w-6 h-6 rounded-lg bg-slate-800 border-white/20 text-green-500 focus:ring-green-500 focus:ring-offset-slate-900" />
                 </div>
             </div>
        </div>
    </div>

    <!-- Right Column: Details -->
    <div class="lg:col-span-2 bg-white rounded-[4rem] p-12 lg:p-20 border border-slate-100 shadow-premium animate-in fade-in slide-in-from-right-8 duration-700 delay-200">
        <div class="space-y-12">
            <!-- Student Identity -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Student Credentials</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Name of Professional</label>
                        <input type="text" @bind="Placement.StudentName" placeholder="Anjali Sharma" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-green-600 outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Batch / Year</label>
                        <input type="text" @bind="Placement.Batch" placeholder="2020-2023" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-green-600 outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                </div>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Academic Track / Course</label>
                    <input type="text" @bind="Placement.Course" placeholder="GNM Nursing" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-green-600 outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                </div>
            </div>

            <!-- Career Milestones -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Career Milestone</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Hiring Institution / Hospital</label>
                        <input type="text" @bind="Placement.HospitalName" placeholder="Apollo Hospitals, Bhubaneswar" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-green-600 outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Designation</label>
                        <input type="text" @bind="Placement.Designation" placeholder="Staff Nurse (ICU)" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-2xl focus:bg-white focus:border-green-600 outline-none transition-all text-sm font-bold placeholder:text-slate-300" />
                    </div>
                </div>

            </div>

            <!-- Testimonial -->
            <div class="space-y-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight border-b border-slate-50 pb-6">Success Statement</h3>
                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Professional Testimonial</label>
                    <textarea @bind="Placement.Testimonial" class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent rounded-3xl focus:bg-white focus:border-green-600 outline-none transition-all text-sm font-light min-h-[150px] leading-relaxed" placeholder="The curriculum and faculty at Ishika were instrumental in my career development..."></textarea>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public long? Id { get; set; }
    private PlacementRecord Placement { get; set; } = new();
    private bool IsSaving { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var existing = await PlacementService.GetPlacementByIdAsync(Id.Value);
            if (existing != null) Placement = existing;
        }
    }

    private async Task HandleSave()
    {
        IsSaving = true;
        try 
        {
            // Sync Media ID
            Placement.StudentPhotoId = Placement.StudentPhoto?.Id;
            
            if (await PlacementService.UpsertPlacementAsync(Placement))
            {
                Navigation.NavigateTo("/admin/placements");
            }
        }
        finally
        {
            IsSaving = false;
        }
    }
}
