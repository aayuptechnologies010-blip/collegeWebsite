@page "/admin/placements"
@using CollegeWebSite.Components.Admin.Layout
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout AdminLayout
@inject IPlacementService PlacementService
@inject NavigationManager Navigation

<PageTitle>Placement Registry | Ishika CMS Admin</PageTitle>

<div class="mb-8 flex flex-col lg:flex-row lg:items-end justify-between gap-4">
    <div class="space-y-2">
        <div class="inline-flex items-center gap-2 px-2.5 py-1 bg-green-50 text-green-600 text-[9px] font-black uppercase tracking-widest rounded-md border border-green-100">
            Success Narratives
        </div>
        <h1 class="text-3xl lg:text-4xl font-black text-slate-900 tracking-tight leading-none">Career <br/><span class="text-slate-400">Milestone Hub.</span></h1>
        <p class="text-slate-500 font-medium text-sm max-w-xl">Central registry for student career triumphs in the medical sector.</p>
    </div>
    
    <button @onclick='() => Navigation.NavigateTo("/admin/placements/edit")' class="group/btn relative px-8 py-3 bg-slate-950 text-white font-black text-[10px] uppercase tracking-[0.2em] rounded-xl shadow-2xl hover:bg-green-600 transition-all overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/10 to-white/0 -translate-x-full group-hover/btn:animate-shimmer"></div>
        <div class="relative flex items-center gap-2">
            <svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M12 4v16m8-8H4" /></svg>
            Register Milestone
        </div>
    </button>
</div>

<div class="bg-white rounded-3xl border border-slate-100 shadow-premium overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50/50">
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Professional Identity</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Institutional Track</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Hiring Nexus</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Impact Status</th>
                    <th class="px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @if (IsLoading)
                {
                    @for(int i=0; i<3; i++)
                    {
                        <tr><td colspan="5" class="px-10 py-12 animate-pulse"><div class="h-8 bg-slate-50 rounded-2xl w-full"></div></td></tr>
                    }
                }
                else if (Placements.Any())
                {
                    @foreach (var record in Placements)
                    {
                        <tr class="group hover:bg-slate-50/50 transition-all">
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="h-10 w-10 rounded-xl bg-slate-100 overflow-hidden border border-slate-200 shrink-0 shadow-inner">
                                        <img src="@(record.StudentPhoto?.Url ?? "images/placeholder-avatar.jpg")" class="w-full h-full object-cover" />
                                    </div>
                                    <div class="space-y-0.5">
                                        <p class="font-black text-slate-900 text-base tracking-tight leading-none">@record.StudentName</p>
                                        <span class="px-1.5 py-0.5 bg-slate-900 text-white text-[7px] font-black uppercase tracking-widest rounded leading-none">Batch @record.Batch</span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <div class="space-y-0.5">
                                    <p class="text-sm font-black text-slate-700 leading-none">@record.Course</p>
                                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Alumni Track</p>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <div class="space-y-0.5">
                                    <p class="text-sm font-black text-green-600 leading-none">@record.HospitalName</p>
                                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">@record.Designation</p>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                @if (record.IsFeatured)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-600 text-[8px] font-black uppercase tracking-[0.1em] border border-amber-100">
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                        Featured
                                    </span>
                                }
                                else
                                {
                                     <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-slate-100 text-slate-400 text-[8px] font-black uppercase tracking-[0.1em] border border-slate-200">
                                        Standard
                                    </span>
                                }
                            </td>
                            <td class="px-8 py-5 text-right">
                                <div class="flex items-center justify-end gap-2 lg:translate-x-2 lg:opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-500">
                                     <button @onclick='() => Navigation.NavigateTo($"/admin/placements/edit/{record.Id}")' class="h-9 w-9 rounded-xl bg-white border border-slate-100 text-slate-400 hover:text-green-500 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center justify-center">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                                    </button>
                                    <button @onclick="() => HandleDelete(record.Id)" class="h-9 w-9 rounded-xl bg-white border border-slate-100 text-slate-400 hover:text-red-500 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center justify-center">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<PlacementRecord> Placements { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlacements();
    }

    private async Task LoadPlacements()
    {
        try 
        {
            IsLoading = true;
            Placements = await PlacementService.GetAllPlacementsAsync();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleDelete(long id)
    {
        if (await PlacementService.DeletePlacementAsync(id))
        {
            await LoadPlacements();
        }
    }
}
