<header class="sticky top-0 z-[100] w-full bg-white/80 backdrop-blur-xl border-b border-white/20 transition-all duration-300 shadow-sm">
    <div class="container-custom flex h-14 items-center justify-between px-4 lg:px-6">
        <!-- Logo: Compact & Sharp -->
        <a href="/" class="flex items-center gap-2 group">
            <div class="relative">
                <div class="h-8 w-8 lg:h-10 lg:w-10 overflow-hidden rounded-lg bg-white flex items-center justify-center p-0.5 shadow-sm group-hover:scale-110 transition-transform">
                    <img src="images/logo.jpeg" alt="Ishika" class="w-full h-full object-contain" />
                </div>
                <div class="absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 lg:h-3 lg:w-3 bg-green-500 border-2 border-white rounded-full"></div>
            </div>
            <div class="flex flex-col">
                <span class="font-black text-slate-900 leading-none text-base lg:text-xl tracking-tighter">ISHIKA</span>
                <span class="text-[7px] lg:text-[8px] text-slate-400 font-bold tracking-[0.15em] uppercase">Nursing</span>
            </div>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-6">
            <NavLink href="/" Match="NavLinkMatch.All" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                Home
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink>
            <NavLink href="/p/about-us" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                About
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink>
  @*           <NavLink href="/curriculum" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                Curriculum
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink> *@
            <NavLink href="/p/gnm-nursing" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                Programs
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink>
            <NavLink href="/faculty" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                Faculty
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink>
            <NavLink href="/gallery" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                Gallery
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink>
            <NavLink href="/events" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                Events
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink>
            <NavLink href="/placements" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                Placements
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink>
@*             <NavLink href="/results" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                Results
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink> *@
            <NavLink href="/p/contact" class="text-[13px] font-bold text-slate-600 hover:text-primary transition-all relative group py-2">
                Contact
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
            </NavLink>
        </nav>

        <!-- Dynamic Action -->
        <div class="flex items-center gap-3">
            <a href="/apply" class="group relative px-4 lg:px-6 py-1.5 lg:py-2.5 bg-primary text-white text-[10px] lg:text-[12px] font-black rounded-xl lg:rounded-2xl shadow-premium overflow-hidden transition-all hover:-translate-y-0.5 active:scale-95">
                <span class="relative z-10 flex items-center gap-2">
                   APPLY <span class="hidden lg:inline">NOW</span>
                   <svg class="w-3 h-3 lg:w-4 lg:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M14 5l7 7-7 7m7-7H3"/></svg>
                </span>
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
            </a>

            <!-- Mobile Toggle -->
            <button @onclick="ToggleMobileMenu" class="lg:hidden p-2 rounded-xl bg-slate-50 text-slate-600 border border-slate-100">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
            </button>
        </div>
    </div>

    <!-- Mobile Drawer -->
    @if (IsMobileMenuOpen)
    {
        <div class="lg:hidden fixed inset-x-0 top-[3.5rem] bg-white border-b border-primary/10 shadow-2xl animate-in fade-in slide-in-from-top-2 duration-300 z-[90]">
            <nav class="flex flex-col p-6 gap-4">
                <NavLink @onclick="CloseMobileMenu" href="/" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">Home <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/p/about-us" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">About <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/curriculum" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">Curriculum <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/p/gnm-nursing" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">Programs <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/faculty" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">Faculty <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/gallery" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">Gallery <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/events" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">Events <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/placements" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">Placements <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/results" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">Results <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/p/contact" class="text-xl font-black text-slate-900 flex items-center justify-between border-b border-slate-50 pb-2">Contact <span class="text-primary">+</span></NavLink>
                <NavLink @onclick="CloseMobileMenu" href="/admin" class="text-xl font-black text-primary flex items-center justify-between">Admin Access <span class="opacity-50">→</span></NavLink>
                
                <div class="mt-6">
                    <a href="/apply" class="block w-full py-4 bg-primary text-white text-center font-black rounded-2xl shadow-premium">BEGIN APPLICATION</a>
                </div>
            </nav>
        </div>
    }
</header>

@code {
    private bool IsMobileMenuOpen { get; set; } = false;
    private void ToggleMobileMenu() { IsMobileMenuOpen = !IsMobileMenuOpen; }
    private void CloseMobileMenu() { IsMobileMenuOpen = false; }
}
