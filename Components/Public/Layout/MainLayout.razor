@inherits LayoutComponentBase

<div class="flex min-h-screen flex-col bg-slate-50 font-sans antialiased text-slate-900 overflow-x-hidden">
    <NoticeTicker />
    <AppHeader />

    <main class="flex-1 w-full pb-10">
        @Body
    </main>

    <AppFooter />
    <PopupManager />
</div>

<div id="blazor-error-ui" class="hidden fixed bottom-0 left-0 right-0 z-[100] bg-amber-100 border-t border-amber-200 p-4 text-amber-900 shadow-lg">
    <div class="container-custom flex items-center justify-between">
        <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-600"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
            An unhandled error has occurred.
        </span>
        <div class="flex gap-4">
            <a href="" class="reload font-semibold hover:underline">Reload</a>
            <span class="dismiss cursor-pointer font-semibold hover:underline">Dismiss</span>
        </div>
    </div>
</div>
