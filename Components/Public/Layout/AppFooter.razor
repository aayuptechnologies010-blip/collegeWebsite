@using Microsoft.Extensions.Options
@using CollegeWebSite.Domain.Settings
@inject IOptions<InstitutionSettings> InstitutionOptions

<footer class="bg-primary border-t border-white/10 text-slate-300 overflow-hidden relative">
    <!-- Subtle Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-primary/5 pointer-events-none"></div>

    <div class="container-custom relative z-10 py-12 lg:py-20">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16">
            
            <!-- Brand & Mission -->
            <div class="space-y-6 text-center md:text-left">
                <a href="/" class="flex flex-col items-center md:items-start gap-2 group">
                    <span class="text-3xl lg:text-4xl font-black text-white tracking-tighter group-hover:text-primary-light transition-colors">ISHIKA</span>
                    <span class="text-[10px] lg:text-[11px] font-black text-slate-400 uppercase tracking-[0.4em]">Nursing & Paramedical</span>
                </a>
                <p class="text-[14px] leading-relaxed text-slate-400 max-w-sm">
                    Odisha's premier institution dedicated to crafting compassionate healthcare leaders through clinical excellence and innovative pedagogy.
                </p>
                <div class="flex justify-center md:justify-start gap-4 pt-4">
                    <a href="@InstitutionOptions.Value.Contact.FacebookUrl" target="_blank" rel="noopener noreferrer" class="h-10 w-10 lg:h-12 lg:w-12 flex items-center justify-center rounded-2xl bg-slate-800 border border-slate-700 hover:bg-primary-light hover:border-primary-light hover:text-primary transition-all group" aria-label="Facebook">
                         <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                    <a href="@InstitutionOptions.Value.Contact.InstagramUrl" target="_blank" rel="noopener noreferrer" class="h-10 w-10 lg:h-12 lg:w-12 flex items-center justify-center rounded-2xl bg-slate-800 border border-slate-700 hover:bg-secondary hover:border-secondary transition-all group" aria-label="Instagram">
                         <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    </a>
                </div>
            </div>

            <!-- Academic Programs -->
            <div class="space-y-6 lg:space-y-8">
                <h3 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-white">Academic Tracks</h3>
                <ul class="space-y-3 lg:space-y-4">
                    <li><a href="/p/gnm-nursing" class="text-[13px] lg:text-[14px] text-slate-400 hover:text-white transition-colors flex items-center gap-3">GNM Nursing <span class="h-1 w-1 rounded-full bg-slate-700"></span></a></li>
                    <li><a href="/p/anm-nursing" class="text-[13px] lg:text-[14px] text-slate-400 hover:text-white transition-colors flex items-center gap-3">ANM Nursing <span class="h-1 w-1 rounded-full bg-slate-700"></span></a></li>
                    <li><a href="/p/bsc-nursing" class="text-[13px] lg:text-[14px] text-slate-400 hover:text-white transition-colors flex items-center gap-3">B.Sc Nursing <span class="h-1 w-1 rounded-full bg-slate-700"></span></a></li>
                </ul>
            </div>

            <!-- Quick Links -->
            <div class="space-y-6 lg:space-y-8">
                <h3 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-white">Institution</h3>
                <ul class="space-y-3 lg:space-y-4">
                    <li><a href="/p/about-us" class="text-[13px] lg:text-[14px] text-slate-400 hover:text-white transition-colors">History & Vision</a></li>
                    <li><a href="/p/infrastructure" class="text-[13px] lg:text-[14px] text-slate-400 hover:text-white transition-colors">Labs & Campus</a></li>
                    <li><a href="/apply" class="text-[13px] lg:text-[14px] text-primary-light font-black hover:underline transition-all">Admissions @(InstitutionOptions.Value.AdmissionsOpen ? InstitutionOptions.Value.AcademicYear.Split('-')[0] : "Closed")</a></li>
                    <li><a href="/p/contact" class="text-[13px] lg:text-[14px] text-slate-400 hover:text-white transition-colors">Contact Support</a></li>
                </ul>
            </div>

            <!-- Institutional Contact -->
            <div class="space-y-6 lg:space-y-8">
                <h3 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-white">Connect</h3>
                <ul class="space-y-3 lg:space-y-6">
                    <li class="flex items-start gap-4">
                        <div class="h-8 w-8 lg:h-10 lg:w-10 rounded-xl bg-white/10 flex items-center justify-center text-primary-light shrink-0">
                             <svg class="w-4 h-4 lg:w-5 lg:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <div class="space-y-2">
                            <span class="text-[12px] lg:text-[13px] text-white/70 leading-relaxed font-medium uppercase tracking-tight block">@InstitutionOptions.Value.Contact.Address</span>
                            <a href="@InstitutionOptions.Value.Contact.NavigationUrl" target="_blank" class="text-[10px] font-black text-primary-light uppercase tracking-widest hover:underline flex items-center gap-1.5">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                Get Directions
                            </a>
                        </div>
                    </li>
                    <li class="flex items-center gap-4">
                        <div class="h-8 w-8 lg:h-10 lg:w-10 rounded-xl bg-white/10 flex items-center justify-center text-secondary shrink-0">
                             <svg class="w-4 h-4 lg:w-5 lg:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        </div>
                        <a href="tel:@InstitutionOptions.Value.Contact.Phone.Replace(" ","")" class="text-[12px] lg:text-[13px] text-white/70 font-black tracking-widest hover:text-white transition-colors">@InstitutionOptions.Value.Contact.Phone</a>
                    </li>
                    <li class="flex items-center gap-4">
                        <div class="h-8 w-8 lg:h-10 lg:w-10 rounded-xl bg-white/10 flex items-center justify-center text-accent shrink-0">
                             <svg class="w-4 h-4 lg:w-5 lg:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        </div>
                        <a href="mailto:@InstitutionOptions.Value.Contact.Email" class="text-[12px] lg:text-[13px] text-white/70 font-medium hover:text-white transition-colors break-all">@InstitutionOptions.Value.Contact.Email</a>
                    </li>
                </ul>
                
                <!-- Google Map Mini -->
                <div class="mt-4 lg:mt-6 rounded-2xl overflow-hidden border border-white/5 h-24 lg:h-32 shadow-premium">
                    <iframe 
                        width="100%" 
                        height="100%" 
                        frameborder="0" 
                        scrolling="no" 
                        marginheight="0" 
                        marginwidth="0" 
                        src="@InstitutionOptions.Value.Contact.GoogleMapsUrl"
                        style="filter: grayscale(1) contrast(1.2) invert(0.9) opacity(0.8);">
                    </iframe>
                </div>
            </div>
        </div>
        
        <!-- Bottom Accreditation Bar -->
        <div class="mt-16 pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="flex items-center gap-8 opacity-40 grayscale hover:grayscale-0 transition-all">
                <span class="text-[11px] font-black tracking-[0.2em] text-white">INC APPROVED</span>
                <span class="text-[11px] font-black tracking-[0.2em] text-white">ONMRC RECOGNIZED</span>
            </div>
            <div class="text-[11px] font-medium text-white/30 text-center md:text-right">
                <p>&copy; @DateTime.Now.Year Ishika Nursing and Paramedical Studies. Built for Academic Excellence.</p>
                <div class="flex justify-center md:justify-end gap-6 mt-3">
                    <NavLink href="/admin" class="hover:text-white transition-colors flex items-center gap-1.5 group/admin">
                         <svg class="w-3 h-3 text-slate-500 group-hover/admin:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                         Control Panel
                    </NavLink>
                    <a href="#" class="hover:text-white transition-colors">Documentation</a>
                    <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
                </div>
            </div>
        </div>
    </div>
</footer>

