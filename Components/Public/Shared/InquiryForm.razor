@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@using CollegeWebSite.Domain.Enums
@inject IInquiryService InquiryService

<div class="bg-white rounded-[3rem] p-8 lg:p-12 shadow-premium">
    <h3 class="text-2xl font-black text-slate-900 mb-8 flex items-center gap-3">
        @Title
        <div class="h-1.5 w-8 rounded-full bg-secondary"></div>
    </h3>
    
    @if (IsSubmitted)
    {
        <div class="text-center space-y-6 animate-in fade-in zoom-in duration-500">
            <div class="h-20 w-20 bg-primary/20 text-primary rounded-3xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <h2 class="text-3xl font-black text-slate-900">@SuccessTitle</h2>
            <p class="text-slate-500 font-light max-w-sm mx-auto">@SuccessMessage</p>
            @if (ShowResetButton)
            {
                <button @onclick="ResetForm" class="px-8 py-3 bg-slate-900 text-white font-black rounded-xl hover:bg-primary transition-all">
                    @ResetButtonText
                </button>
            }
        </div>
    }
    else
    {
        <EditForm Model="Inquiry" OnValidSubmit="HandleSubmit" FormName="@FormName" class="space-y-6">
            <DataAnnotationsValidator />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Name *</label>
                    <InputText @bind-Value="Inquiry.Name" 
                               class="w-full px-5 py-3 bg-slate-50 rounded-2xl border border-slate-100 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all text-sm font-medium" 
                               placeholder="Your full name" />
                    <ValidationMessage For="@(() => Inquiry.Name)" class="text-[10px] text-red-500 mt-1" />
                </div>
                
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Email *</label>
                    <InputText @bind-Value="Inquiry.Email" 
                               type="email"
                               class="w-full px-5 py-3 bg-slate-50 rounded-2xl border border-slate-100 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all text-sm font-medium" 
                               placeholder="your@email.com" />
                    <ValidationMessage For="@(() => Inquiry.Email)" class="text-[10px] text-red-500 mt-1" />
                </div>
            </div>
            
            @if (ShowPhoneField)
            {
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Phone Number</label>
                    <InputText @bind-Value="Inquiry.PhoneNumber" 
                               class="w-full px-5 py-3 bg-slate-50 rounded-2xl border border-slate-100 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all text-sm font-medium" 
                               placeholder="+91 1234567890" />
                </div>
            }
            
            @if (ShowSubjectField)
            {
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Subject</label>
                    <InputText @bind-Value="Inquiry.Subject" 
                               class="w-full px-5 py-3 bg-slate-50 rounded-2xl border border-slate-100 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all text-sm font-medium" 
                               placeholder="What is this regarding?" />
                </div>
            }
            
            <div class="space-y-2">
                <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Message *</label>
                <InputTextArea @bind-Value="Inquiry.Message" 
                               rows="5"
                               class="w-full px-5 py-3 bg-slate-50 rounded-2xl border border-slate-100 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all text-sm font-medium" 
                               placeholder="Tell us how we can help you..."></InputTextArea>
                <ValidationMessage For="@(() => Inquiry.Message)" class="text-[10px] text-red-500 mt-1" />
            </div>
            
            <button type="submit" 
                    disabled="@IsSubmitting" 
                    class="w-full py-4 bg-slate-900 text-white font-black rounded-2xl hover:bg-primary transition-all shadow-xl active:scale-[0.98] flex items-center justify-center gap-3 disabled:opacity-50">
                @if (IsSubmitting)
                {
                    <span class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                    <span>@SubmittingText</span>
                }
                else
                {
                    <span>@SubmitButtonText</span>
                }
            </button>
        </EditForm>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Send Message";
    [Parameter] public string Subject { get; set; } = "Website Inquiry";
    [Parameter] public bool ShowPhoneField { get; set; } = true;
    [Parameter] public bool ShowSubjectField { get; set; } = false;
    [Parameter] public string SubmitButtonText { get; set; } = "SEND MESSAGE";
    [Parameter] public string SubmittingText { get; set; } = "SENDING...";
    [Parameter] public string SuccessTitle { get; set; } = "Message Sent";
    [Parameter] public string SuccessMessage { get; set; } = "We've received your query. A campus representative will get back to you shortly.";
    [Parameter] public bool ShowResetButton { get; set; } = true;
    [Parameter] public string ResetButtonText { get; set; } = "Send Another";
    [Parameter] public string FormName { get; set; } = "InquiryForm";
    [Parameter] public EventCallback<Inquiry> OnSubmitted { get; set; }

    private Inquiry Inquiry { get; set; } = new();
    private bool IsSubmitted { get; set; } = false;
    private bool IsSubmitting { get; set; } = false;

    private async Task HandleSubmit()
    {
        IsSubmitting = true;
        try
        {
            Inquiry.Subject = Subject;
            Inquiry.Status = InquiryStatus.New;
            Inquiry.SubmittedOn = DateTime.UtcNow;
            
            await InquiryService.CreateInquiryAsync(Inquiry);
            IsSubmitted = true;
            
            await OnSubmitted.InvokeAsync(Inquiry);
        }
        catch (Exception ex)
        {
            // Error handling - could be enhanced with toast notifications
            Console.WriteLine($"Error submitting inquiry: {ex.Message}");
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void ResetForm()
    {
        Inquiry = new();
        IsSubmitted = false;
        IsSubmitting = false;
    }
}
