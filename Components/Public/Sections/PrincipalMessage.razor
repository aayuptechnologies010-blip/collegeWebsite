@using Microsoft.Extensions.Options
@using CollegeWebSite.Domain.Settings
@inject IOptions<InstitutionSettings> InstitutionOptions

<section class="py-12 lg:py-20 bg-white relative overflow-hidden px-6 lg:px-0">
    <div class="container-custom relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-16">
            <!-- Image Area: Top on Mobile -->
            <div class="w-full max-w-[280px] lg:w-4/12 relative mx-auto lg:mx-0 order-1 group">
                <div class="relative z-10 rounded-3xl overflow-hidden shadow-premium border border-slate-100 group-hover:shadow-2xl transition-all duration-700">
                    <img src="@InstitutionOptions.Value.Principal.ImageUrl" class="w-full aspect-[4/5] object-cover group-hover:scale-110 transition-transform duration-1000" />
                    <div class="absolute bottom-4 left-4 bg-white p-3 rounded-2xl shadow-xl flex flex-col items-center">
                        <p class="text-primary font-black text-xl lg:text-2xl leading-none">@InstitutionOptions.Value.Principal.ExperienceYears<span class="text-secondary italic">+</span></p>
                        <p class="text-[8px] font-black uppercase tracking-widest text-slate-400 mt-1">YEARS EXP.</p>
                    </div>
                </div>
                <!-- Backing Shape -->
                <div class="absolute -top-10 -right-10 w-48 h-48 bg-secondary/5 rounded-full blur-3xl -z-10 animate-pulse"></div>
            </div>

            <!-- Text Content: Bottom on Mobile -->
            <div class="w-full lg:w-8/12 space-y-6 lg:space-y-8 text-center lg:text-left order-2">
                <div class="space-y-4">
                    <span class="inline-block px-3 py-1 rounded-full bg-primary/5 text-primary text-[10px] font-black uppercase tracking-widest">
                        ACADEMIC LEADERSHIP
                    </span>
                    <h2 class="text-3xl lg:text-4xl font-black text-slate-900 leading-tight uppercase">
                        Quality <span class="text-secondary italic">Nursing Excellence</span> <br class="hidden lg:block" />
                        Built with Compassion
                    </h2>
                </div>

                <div class="relative">
                    <p class="text-slate-600 text-[14px] lg:text-[18px] font-bold leading-relaxed italic lg:pr-12 uppercase tracking-tight">
                        "@InstitutionOptions.Value.Principal.Message"
                    </p>
                </div>
                
                <div class="flex flex-col sm:flex-row items-center gap-6 pt-6 border-t border-slate-100 justify-center lg:justify-start">
                    <div class="h-14 w-14 rounded-2xl bg-secondary-light text-secondary flex items-center justify-center shadow-lg shadow-black/5">
                         <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </div>
                    <div>
                        <h4 class="text-2xl font-black text-slate-950 leading-none uppercase">@InstitutionOptions.Value.Principal.Name</h4>
                        <p class="text-[10px] text-secondary font-black uppercase tracking-widest mt-2">@InstitutionOptions.Value.Principal.Title</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

