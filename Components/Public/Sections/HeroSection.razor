@using Microsoft.Extensions.Options
@using CollegeWebSite.Domain.Settings
@using CollegeWebSite.Domain.Entities
@using CollegeWebSite.Services.Interfaces
@inject IOptions<InstitutionSettings> InstitutionOptions
@inject IHeroService HeroService

<section class="relative bg-white overflow-hidden flex items-center selection:bg-primary/10 selection:text-primary min-h-[500px] lg:min-h-[650px]">
    <!-- Animated Blob Backgrounds -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
        <div class="absolute top-[-5%] right-[-5%] w-[30rem] lg:w-[50rem] h-[30rem] lg:h-[50rem] bg-primary/5 rounded-full mix-blend-multiply blur-[80px] lg:blur-[120px] animate-blob"></div>
        <div class="absolute bottom-[-5%] left-[-5%] w-[25rem] lg:w-[45rem] h-[25rem] lg:h-[45rem] bg-secondary/5 rounded-full mix-blend-multiply blur-[80px] lg:blur-[120px] animate-blob" style="animation-delay: 2s"></div>
    </div>

    <div class="container-custom relative z-10 py-8 lg:py-16">
        <div class="flex flex-col lg:grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
            
            <!-- Content Area -->
            <div class="lg:col-span-5 space-y-6 lg:space-y-8 order-2 lg:order-1 text-center lg:text-left animate-parallax px-4 lg:px-0">
                @if (InstitutionOptions.Value.AdmissionsOpen)
                {
                    <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full bg-primary-light border border-primary/10 text-primary text-[12px] lg:text-[14px] font-black tracking-widest mx-auto lg:ml-0 shadow-sm uppercase">
                        <span class="flex h-2 w-2 rounded-full bg-secondary animate-pulse"></span>
                        @Hero?.WelcomeBadge @InstitutionOptions.Value.AcademicYear
                        <span class="hidden sm:inline text-slate-400 font-bold ml-2">| ONMRC RECOGNIZED</span>
                    </div>
                }
                
                <div class="space-y-6 lg:space-y-8">
                    <h1 class="text-2xl sm:text-4xl md:text-2xl lg:text-4xl xl:text-4xl font-black tracking-tighter text-slate-900 leading-[0.95] uppercase">
                        @Hero?.HeadlineMain <br />
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-blue-700 to-secondary animate-shine bg-[length:200%_auto] italic">@Hero?.HeadlineShine</span>
                    </h1>
                    
                    <p class="text-[16px] lg:text-[20px] text-slate-600 leading-relaxed max-w-3xl mx-auto lg:ml-0 font-medium lg:pr-16 uppercase tracking-tight">
                        @Hero?.SubHeadline
                    </p>
                </div>
                
                <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-6 pt-6">
                    <a href="@Hero?.PrimaryButtonLink" class="px-10 py-5 text-[14px] font-black uppercase tracking-widest text-white bg-primary rounded-2xl shadow-premium border border-white/10 hover:shadow-2xl hover:-translate-y-1.5 transition-all text-center flex items-center justify-center gap-3">
                        @Hero?.PrimaryButtonText
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                    </a>
                    <a href="@Hero?.SecondaryButtonLink" class="px-10 py-5 text-[14px] font-black uppercase tracking-widest text-slate-700 bg-white border border-slate-200 rounded-2xl shadow-sm hover:bg-slate-50 hover:shadow-md hover:-translate-y-1 transition-all text-center">
                         @Hero?.SecondaryButtonText
                    </a>
                </div>

                <!-- Stats Row -->
                <div class="pt-8 grid grid-cols-3 gap-4 lg:flex lg:items-center lg:gap-10 lg:justify-start border-t border-slate-100 mt-10">
                    <div class="flex flex-col items-center lg:items-start group">
                        <span class="text-2xl lg:text-3xl font-black text-slate-950 leading-none group-hover:text-primary transition-colors">@Hero?.Stat1Value</span>
                        <span class="text-[9px] lg:text-[10px] font-black text-slate-400 uppercase tracking-widest mt-2 text-center lg:text-left">@Hero?.Stat1Label</span>
                    </div>
                    <div class="flex flex-col items-center lg:items-start group">
                         <span class="text-2xl lg:text-3xl font-black text-secondary leading-none group-hover:scale-110 transition-transform">@Hero?.Stat2Value</span>
                         <span class="text-[9px] lg:text-[10px] font-black text-slate-400 uppercase tracking-widest mt-2 text-center lg:text-left">@Hero?.Stat2Label</span>
                    </div>
                    <div class="flex flex-col items-center lg:items-start group">
                         <span class="text-2xl lg:text-3xl font-black text-primary leading-none group-hover:rotate-3 transition-transform">@Hero?.Stat3Value</span>
                         <span class="text-[9px] lg:text-[10px] font-black text-slate-400 uppercase tracking-widest mt-2 text-center lg:text-left">@Hero?.Stat3Label</span>
                    </div>
                </div>
            </div>
            
            <!-- Right Visual -->
            <div class="lg:col-span-7 relative order-1 lg:order-2 w-full max-w-2xl lg:max-w-none mx-auto">
                <div class="relative z-20 group">
                    <div class="relative bg-white rounded-[2rem] lg:rounded-[3rem] shadow-premium border border-slate-100 p-2 lg:p-3 rotate-2 group-hover:rotate-0 transition-transform duration-700">
                        <div class="w-full rounded-[1.8rem] lg:rounded-[2.5rem] overflow-hidden relative">
                             <img src="@Hero?.BannerImagePath" alt="Ishika Campus Animation" class="w-full h-auto object-contain transition-all duration-1000 group-hover:brightness-105" />
                        </div>
                    </div>
                    
                    <!-- Floating Badge -->
                    <div class="absolute -bottom-10 right-6 lg:-bottom-16 lg:-left-12 bg-white p-4 lg:p-5 rounded-[1.5rem] lg:rounded-[2rem] shadow-2xl border border-slate-50 z-30 animate-float">
                        <div class="flex items-center gap-3">
                            <div class="h-10 w-10 lg:h-12 lg:w-12 bg-green-500 text-white rounded-xl flex items-center justify-center shadow-lg shadow-green-200">
                                <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M5 13l4 4L19 7" /></svg>
                            </div>
                            <div class="text-left">
                                <p class="text-[13px] lg:text-[14px] font-black text-slate-950 leading-tight">@Hero?.BadgeStatus</p>
                                <p class="text-[9px] lg:text-[10px] text-slate-400 font-bold uppercase tracking-widest">@Hero?.BadgeLabel</p>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Background Glow -->
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[150%] h-[150%] bg-primary/10 rounded-full blur-[100px] lg:blur-[140px] -z-10"></div>
            </div>
        </div>
    </div>
</section>

@code {
    private HeroContent? Hero { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Hero = await HeroService.GetActiveHeroContentAsync();
        
        // Fallback to default if DB is empty
        if (Hero == null)
        {
            Hero = new HeroContent();
        }
    }
}
