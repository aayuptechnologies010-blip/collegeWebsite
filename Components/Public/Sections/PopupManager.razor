@using CollegeWebSite.Domain.Entities
@using CollegeWebSite.Domain.Enums
@using CollegeWebSite.Services.Interfaces
@inject IPopupService PopupService
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

@if (ActivePopup != null)
{
    @if (ActivePopup.Type == PopUpType.Modal)
    {
        <!-- MODAL SYSTEM -->
        <div class="fixed inset-0 bg-slate-950/60 backdrop-blur-[2px] flex items-center justify-center p-4 lg:p-12 animate-in fade-in duration-500" style="z-index: @(ZIndex + 1)">
            <div class="relative w-auto max-w-xl animate-in zoom-in-95 slide-in-from-bottom-8 duration-700 delay-@ActivePopup.DelaySeconds">
                <!-- Close Button (Floating Outside) -->
                <button @onclick="Dismiss" class="absolute -top-10 right-0 lg:-right-10 h-8 w-8 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white hover:text-slate-900 transition-all border border-white/20 shadow-2xl z-[10001]">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M6 18L18 6M6 6l12 12"/></svg>
                </button>

                <div class="bg-white rounded-[1.5rem] w-fit max-w-[calc(100vw-2rem)] md:max-w-[320px] max-h-[65vh] md:max-h-[420px] overflow-hidden shadow-2xl relative flex flex-col mx-auto transition-all">
                    
                    @if (!string.IsNullOrEmpty(ActivePopup.ImageUrl))
                    {
                        <div class="bg-slate-50 flex items-center justify-center overflow-hidden shrink min-h-0 border-b border-slate-50">
                            <img src="@ActivePopup.ImageUrl" class="w-auto h-auto max-w-full max-h-[20vh] md:max-h-[150px] object-contain" alt="Announcement Banner" />
                        </div>
                    }

                    <div class="p-5 lg:p-6 space-y-4 text-center overflow-y-auto custom-scrollbar grow">
                        <div class="space-y-3">
                            @if (!string.IsNullOrEmpty(ActivePopup.IconName))
                            {
                                <div class="h-10 w-10 bg-primary/5 text-primary rounded-xl flex items-center justify-center mx-auto mb-3">
                                    <i class="lucide-@ActivePopup.IconName w-5 h-5"></i>
                                </div>
                            }
                            
                            <h2 class="text-lg lg:text-xl font-black text-slate-900 tracking-tighter uppercase leading-none">@ActivePopup.Title</h2>
                            <div class="text-[13px] text-slate-600 leading-relaxed font-medium">
                                @((MarkupString)ActivePopup.ContentHtml)
                            </div>
                        </div>

                        <div class="flex flex-col gap-2 pt-2">
                            @if (!string.IsNullOrEmpty(ActivePopup.PrimaryButtonText))
                            {
                                <button @onclick='() => HandleClick(ActivePopup.PrimaryButtonUrl)' class="w-full px-6 py-3 bg-primary text-white text-[9px] font-black uppercase tracking-[0.2em] rounded-lg shadow-xl shadow-primary/20 hover:-translate-y-0.5 transition-all">
                                    @ActivePopup.PrimaryButtonText
                                </button>
                            }
                            @if (!string.IsNullOrEmpty(ActivePopup.SecondaryButtonText))
                            {
                                <button @onclick="Dismiss" class="w-full px-6 py-3 bg-white text-slate-900 border border-slate-200 text-[9px] font-black uppercase tracking-[0.2em] rounded-lg hover:bg-slate-50 transition-all">
                                    @ActivePopup.SecondaryButtonText
                                </button>
                            }
                        </div>

                        <button @onclick="Dismiss" class="text-[8px] font-black uppercase tracking-[0.4em] text-slate-400 hover:text-slate-900 transition-all pt-2">
                            CLOSE
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (ActivePopup.Type == PopUpType.Banner)
    {
        <!-- BANNER SYSTEM (Top Persistent) -->
        <div class="fixed top-0 inset-x-0 bg-slate-900 text-white py-3.5 px-6 animate-in slide-in-from-top duration-500 flex items-center justify-between border-b border-white/5 shadow-2xl" style="z-index: @(ZIndex + 1)">
            <div class="flex items-center gap-4 max-w-4xl">
                 <span class="px-2.5 py-0.5 bg-primary text-[8px] font-black uppercase rounded tracking-widest">Protocol-Active</span>
                 <p class="text-[11px] lg:text-[13px] font-bold tracking-tight uppercase">@ActivePopup.Title: <span class="text-slate-400">@((MarkupString)ActivePopup.ContentHtml)</span></p>
            </div>
            <div class="flex items-center gap-6">
                @if (!string.IsNullOrEmpty(ActivePopup.PrimaryButtonText))
                {
                    <button @onclick='() => HandleClick(ActivePopup.PrimaryButtonUrl)' class="text-[9px] font-black uppercase tracking-[0.2em] hover:text-primary transition-colors border-b-2 border-primary/40 pb-0.5">@ActivePopup.PrimaryButtonText</button>
                }
                <button @onclick="Dismiss" class="text-slate-500 hover:text-white transition-colors">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
    }
}

@code {
    private AnnouncementPopUp? ActivePopup { get; set; }
    private double ZIndex { get; set; } = 1000;

    protected override void OnInitialized()
    {
        DialogService.OnShow += HandleManualPopup;
    }

    private async void HandleManualPopup(AnnouncementPopUp popup)
    {
        ZIndex = await JS.InvokeAsync<double>("popupManager.getMaxZIndex");
        ActivePopup = popup;
        StateHasChanged();
    }

    public void Dispose()
    {
        DialogService.OnShow -= HandleManualPopup;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadRelevantPopup();
        }
    }

    private async Task LoadRelevantPopup()
    {
        try
        {
            // Simple mobile detection heuristic for targeting
            bool isMobile = false; // Could be improved with JS detection
            var relevant = await PopupService.GetRelevantPopupsAsync(Nav.Uri, isMobile);

            foreach (var popup in relevant)
            {
                // Check browser storage for "Seen/Skip" rules (frequency)
                bool shouldShow = await JS.InvokeAsync<bool>("popupManager.checkFrequency", popup.Id, (int)popup.Frequency);
                
                if (shouldShow)
                {
                    ZIndex = await JS.InvokeAsync<double>("popupManager.getMaxZIndex");
                    ActivePopup = popup;
                    await PopupService.RecordImpressionAsync(popup.Id);
                    StateHasChanged();
                    break; // Only show one (highest priority)
                }
            }
        }
        catch (Exception ex)
        {
            // Silently fail to not break public UI
        }
    }

    private async Task Dismiss()
    {
        if (ActivePopup == null) return;
        
        await PopupService.RecordDismissalAsync(ActivePopup.Id);
        await JS.InvokeVoidAsync("popupManager.markSeen", ActivePopup.Id, (int)ActivePopup.Frequency);
        ActivePopup = null;
        StateHasChanged();
    }

    private async Task HandleClick(string? url)
    {
        if (ActivePopup == null) return;

        await PopupService.RecordClickAsync(ActivePopup.Id);
        await JS.InvokeVoidAsync("popupManager.markSeen", ActivePopup.Id, (int)ActivePopup.Frequency);
        
        var redirectUrl = url;
        ActivePopup = null;
        StateHasChanged();

        if (!string.IsNullOrEmpty(redirectUrl))
        {
            Nav.NavigateTo(redirectUrl);
        }
    }
}

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.05); border-radius: 20px; }
</style>
