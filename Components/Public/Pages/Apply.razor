@page "/apply"
@using CollegeWebSite.Services.Interfaces
@using Microsoft.Extensions.Options
@using CollegeWebSite.Domain.Settings
@using CollegeWebSite.Domain.Entities
@using CollegeWebSite.Components.Public.Layout
@using CollegeWebSite.Components.Shared
@using System.ComponentModel.DataAnnotations
@inject IOptions<InstitutionSettings> InstitutionOptions
@inject IInquiryService InquiryService
@inject NavigationManager NavManager
@inject ISeoService SeoService
@layout MainLayout

<SeoHead Title="Apply for Admission | Ishika Nursing & Paramedical Studies"
         Description="@($"Apply for GNM, ANM, or B.Sc Nursing at Ishika Nursing & Paramedical College, Kendujhar. Admissions {InstitutionOptions.Value.AcademicYear} session.")"
         Keywords="Ishika nursing admission, GNM application Odisha, ANM apply Kendujhar, nursing college enrollment"
         CanonicalUrl="/apply" />

<StructuredData JsonLd="@SeoService.GenerateCourseSchema("GNM Nursing", "3-year General Nursing and Midwifery program at Ishika.")" />
<StructuredData JsonLd="@SeoService.GenerateCourseSchema("ANM Nursing", "2-year Auxiliary Nurse Midwifery program at Ishika.")" />

<section class="py-12 lg:py-20 bg-white relative overflow-hidden">
    <!-- Background Accents -->
    <div class="absolute top-0 right-0 w-[45rem] h-[45rem] bg-primary/5 rounded-full blur-[120px] -z-0"></div>
    <div class="absolute bottom-0 left-0 w-[40rem] h-[40rem] bg-secondary/5 rounded-full blur-[100px] -z-0"></div>

    <div class="container-custom relative z-10">
        <div class="flex flex-col lg:flex-row gap-10 lg:gap-16 items-start">
            
            <!-- Information & Guidance -->
            <div class="w-full lg:w-5/12 space-y-12">
                <div class="space-y-6">
                    <span class="inline-block px-5 py-2 rounded-full bg-primary/5 text-primary text-[12px] font-black uppercase tracking-widest leading-none">
                        ADMISSIONS @InstitutionOptions.Value.AcademicYear
                    </span>
                    <h1 class="text-4xl lg:text-5xl xl:text-6xl font-black text-slate-900 leading-tight uppercase">
                        Begin Your <br />
                        <span class="text-secondary italic">Nursing Journey</span> Here.
                    </h1>
                    <p class="text-slate-500 font-bold text-[16px] lg:text-[20px] leading-relaxed max-w-md uppercase tracking-tight">
                        Join a community dedicated to medical excellence. Our streamlined application process takes less than 10 minutes to complete.
                    </p>
                </div>

                <div class="space-y-8">
                    <div class="flex gap-6 group">
                        <div class="h-12 w-12 shrink-0 rounded-2xl bg-primary text-white flex items-center justify-center text-[16px] font-black shadow-lg shadow-primary/20">1</div>
                        <div>
                            <h4 class="text-[16px] font-black text-slate-900 uppercase leading-none mb-2">Choose Program</h4>
                            <p class="text-[13px] text-slate-400 font-bold uppercase">Select GNM, ANM, or B.Sc tracks.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 group">
                        <div class="h-12 w-12 shrink-0 rounded-2xl bg-primary text-white flex items-center justify-center text-[16px] font-black shadow-lg shadow-primary/20">2</div>
                        <div>
                            <h4 class="text-[16px] font-black text-slate-900 uppercase leading-none mb-2">Upload Credentials</h4>
                            <p class="text-[13px] text-slate-400 font-bold uppercase">Keep ID and Academic Marksheets ready.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 group">
                        <div class="h-12 w-12 shrink-0 rounded-2xl bg-secondary text-white flex items-center justify-center text-[16px] font-black shadow-lg shadow-secondary/20">3</div>
                        <div>
                            <h4 class="text-[16px] font-black text-slate-900 uppercase leading-none mb-2">Interview Call</h4>
                            <p class="text-[13px] text-slate-400 font-bold uppercase">Our academic head will reach out shortly.</p>
                        </div>
                    </div>
                </div>

                <!-- Support Card -->
                <div class="p-8 bg-slate-50 rounded-3xl border border-slate-100 space-y-4">
                    <p class="text-[11px] font-black text-slate-400 uppercase tracking-widest">NEED ASSISTANCE?</p>
                    <div class="flex items-center gap-5">
                        <div class="h-14 w-14 rounded-2xl bg-white flex items-center justify-center text-primary shadow-sm border border-slate-100">
                             <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        </div>
                        <div>
                            <p class="text-xl font-black text-slate-950 leading-none">@InstitutionOptions.Value.Contact.Phone</p>
                            <p class="text-[11px] text-slate-400 font-black uppercase mt-2">Admission Liaison Desk</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Area -->
            <div class="w-full lg:w-7/12">
                @if (IsSubmitted)
                {
                    <div class="bg-white rounded-3xl p-16 lg:p-24 shadow-premium border border-slate-100 text-center space-y-6">
                        <div class="h-20 w-20 bg-green-100 text-green-600 rounded-2xl flex items-center justify-center mx-auto shadow-sm">
                            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M5 13l4 4L19 7" /></svg>
                        </div>
                        <h2 class="text-3xl font-black text-slate-900 uppercase">Application received</h2>
                        <p class="text-[13px] text-slate-500 font-bold max-w-sm mx-auto uppercase leading-relaxed">Thank you for choosing Ishika. Our admissions team will review your application and contact you within 24-48 hours via email or phone.</p>
                        <button @onclick="ResetForm" class="px-10 py-4 bg-primary text-white font-black rounded-2xl shadow-xl hover:opacity-90 transition-all uppercase text-[12px] tracking-widest">Submit another</button>
                    </div>
                }
                else
                {
                    <div class="bg-white rounded-3xl shadow-premium border border-slate-50 p-10 lg:p-14">
                        <div class="flex items-center justify-between mb-10">
                            <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight leading-none">Application form</h2>
                            <div class="flex gap-2">
                                <div class="h-1.5 w-6 rounded-full bg-primary font-black"></div>
                                <div class="h-1.5 w-6 rounded-full bg-slate-100"></div>
                            </div>
                        </div>
 
                        <EditForm Model="Application" OnValidSubmit="HandleSubmit" FormName="AdmissionApplication" class="space-y-6">
                            <DataAnnotationsValidator />
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="text-[12px] font-black uppercase tracking-widest text-slate-400 px-1">Full name</label>
                                    <InputText @bind-Value="Application.Name" class="w-full px-6 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:border-primary transition-all text-[16px] font-bold uppercase" placeholder="Enter your full name" />
                                    <ValidationMessage For="@(() => Application.Name)" class="text-[11px] text-red-500 font-bold ml-1" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[12px] font-black uppercase tracking-widest text-slate-400 px-1">Email address</label>
                                    <InputText @bind-Value="Application.Email" type="email" class="w-full px-6 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:border-primary transition-all text-[16px] font-bold uppercase" placeholder="email@address.com" />
                                    <ValidationMessage For="@(() => Application.Email)" class="text-[11px] text-red-500 font-bold ml-1" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[12px] font-black uppercase tracking-widest text-slate-400 px-1">Phone number</label>
                                    <InputText @bind-Value="Application.PhoneNumber" class="w-full px-6 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:border-primary transition-all text-[16px] font-bold" placeholder="+91 00000 00000" />
                                    <ValidationMessage For="@(() => Application.PhoneNumber)" class="text-[11px] text-red-500 font-bold ml-1" />
                                </div>
                                 <div class="space-y-2">
                                    <label class="text-[12px] font-black uppercase tracking-widest text-slate-400 px-1">Interested program</label>
                                    <InputSelect @bind-Value="Application.InterestedProgram" class="w-full px-6 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:border-primary transition-all text-[16px] font-black appearance-none cursor-pointer uppercase">
                                        <option value="GNM Nursing (3 Years)">GNM Nursing (3 Years)</option>
                                        <option value="ANM Nursing (2 Years)">ANM Nursing (2 Years)</option>
                                        <option value="B.Sc Nursing (4 Years)">B.Sc Nursing (4 Years)</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => Application.InterestedProgram)" class="text-[11px] text-red-500 font-bold ml-1" />
                                </div>
                            </div>
 
                            <div class="space-y-2">
                                 <label class="text-[12px] font-black uppercase tracking-widest text-slate-400 px-1">Residential address</label>
                                 <InputTextArea @bind-Value="Application.ResidentialAddress" rows="4" class="w-full px-6 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:border-primary transition-all text-[16px] font-bold uppercase" placeholder="Enter your complete residential address..."></InputTextArea>
                                 <ValidationMessage For="@(() => Application.ResidentialAddress)" class="text-[11px] text-red-500 font-bold ml-1" />
                            </div>
 
                            <div class="pt-4">
                                <button type="submit" disabled="@IsSubmitting" class="w-full py-5 bg-primary text-white font-black rounded-2xl shadow-premium border border-white/10 hover:opacity-95 transition-all flex items-center justify-center gap-3 disabled:opacity-50 text-[12px] uppercase tracking-widest leading-none">
                                    @if(IsSubmitting)
                                    {
                                        <span class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                                        <span>Processing data...</span>
                                    }
                                    else
                                    {
                                        <span>Submit official application</span>
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                                    }
                                </button>
                                <div class="flex items-center justify-center gap-2 mt-4">
                                    <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>
                                    <p class="text-[8px] text-slate-400 font-black uppercase tracking-widest italic">Secure & Confidential Academic Enrollment</p>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                }
            </div>

        </div>
    </div>
</section>

@code {
    private ApplicationModel Application { get; set; } = new();
    private bool IsSubmitted { get; set; } = false;
    private bool IsSubmitting { get; set; } = false;

    private async Task HandleSubmit()
    {
        IsSubmitting = true;
        try 
        {
            var inquiry = new Inquiry
            {
                Name = Application.Name,
                Email = Application.Email,
                PhoneNumber = Application.PhoneNumber,
                Subject = $"Admission Application: {Application.InterestedProgram}",
                Message = $"COURSE: {Application.InterestedProgram}\nRESIDENTIAL ADDRESS: {Application.ResidentialAddress}",
                Status = CollegeWebSite.Domain.Enums.InquiryStatus.New,
                SubmittedOn = DateTime.UtcNow
            };
            
            await InquiryService.CreateInquiryAsync(inquiry);
            IsSubmitted = true;
        }
        catch (Exception ex)
        {
            // Error handling logic
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void ResetForm()
    {
        Application = new();
        IsSubmitted = false;
        IsSubmitting = false;
    }

    public class ApplicationModel
    {
        [Required(ErrorMessage = "Enter your full name")]
        [StringLength(100, ErrorMessage = "Name is too long")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email address is mandatory")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Phone number is required")]
        [Phone(ErrorMessage = "Please enter a valid phone number")]
        [StringLength(15, MinimumLength = 10, ErrorMessage = "Invalid phone number")]
        public string PhoneNumber { get; set; } = string.Empty;

        [Required(ErrorMessage = "Select at least one program")]
        public string InterestedProgram { get; set; } = "GNM Nursing (3 Years)";

        [Required(ErrorMessage = "Residential address is required")]
        public string ResidentialAddress { get; set; } = string.Empty;
    }
}
