@page "/not-found"
@using CollegeWebSite.Components.Public.Layout
@layout MainLayout

<SeoHead Title="404 - Page Not Found | Ishika Nursing & Paramedical Studies"
         Description="The page you requested could not be found. Return to the Ishika Nursing College homepage or contact us for help."
         NoIndex="true" />

<section class="min-h-[85vh] flex items-center justify-center relative overflow-hidden bg-white px-4 selection:bg-red-50 selection:text-red-500">
     <!-- Abstract Errors Background -->
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-red-500/5 rounded-full blur-[100px] animate-pulse"></div>
        <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-primary/5 rounded-full blur-[100px] animate-blob"></div>
    </div>

    <div class="container-custom relative z-10 text-center space-y-8 animate-parallax">
        <div class="relative inline-block group">
            <div class="text-[8rem] lg:text-[12rem] font-black text-slate-900/5 leading-none select-none">404</div>
            <div class="absolute inset-0 flex items-center justify-center">
                <div class="h-20 w-20 lg:h-32 lg:w-32 bg-white rounded-[2rem] shadow-premium flex items-center justify-center text-red-500 border border-red-50 group-hover:rotate-12 transition-transform duration-500">
                    <svg class="w-10 h-10 lg:w-16 lg:h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                </div>
            </div>
        </div>

        <div class="space-y-4 max-w-lg mx-auto">
            <h1 class="text-3xl lg:text-5xl font-black text-slate-900">Campus Link Lost</h1>
            <p class="text-sm lg:text-lg text-slate-500 font-light leading-relaxed">
                The resource you're seeking has either been moved to another department or doesn't exist in our current directory.
            </p>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
            <a href="/" class="px-8 py-4 bg-slate-900 text-white font-black rounded-2xl shadow-xl hover:bg-primary transition-all flex items-center gap-3">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                Back to Campus
            </a>
            <a href="/p/contact" class="px-8 py-4 bg-white text-slate-700 font-bold rounded-2xl border border-slate-100 hover:bg-slate-50 transition-all">
                Registry Support
            </a>
        </div>
    </div>
</section>
