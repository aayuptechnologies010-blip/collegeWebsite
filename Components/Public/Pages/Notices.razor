@page "/notices"
@using CollegeWebSite.Components.Public.Layout
@using CollegeWebSite.Components.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout MainLayout
@inject INoticeService NoticeService

<SeoHead Title="Notices & Announcements | Ishika Nursing & Paramedical Studies"
         Description="Official notices, exam schedules, admission updates, and announcements from Ishika Nursing & Paramedical College, Kendujhar."
         Keywords="Ishika notices, nursing college announcements Odisha, Kendujhar college news, exam schedule Ishika" />

<!-- Master Header -->
<section class="relative py-16 lg:py-24 bg-slate-900 overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[40rem] h-[40rem] bg-amber-500/10 rounded-full blur-[100px] -z-0"></div>
    <div class="container-custom relative z-10">
        <div class="max-w-4xl space-y-6">
            <span class="inline-block px-3 py-1 rounded-full bg-white/5 text-amber-500 text-[10px] font-black uppercase tracking-widest border border-white/5 mb-2">
                REGISTRY & GOVERNANCE
            </span>
            <h1 class="text-3xl lg:text-5xl font-black text-white leading-tight uppercase tracking-tight">
                Official Institutional <br />
                <span class="text-amber-500 italic">Directives.</span>
            </h1>
            <p class="text-slate-400 font-bold text-[14px] lg:text-[16px] leading-relaxed max-w-3xl uppercase tracking-tight">
                Stay informed with the latest administrative protocols, academic calendars, and authoritative institutional announcements from the Ishika Registry.
            </p>
        </div>
    </div>
</section>

<!-- Notice Board -->
<section class="pb-24 lg:pb-32 bg-slate-50">
    <div class="container-custom">
        <div class="max-w-5xl mx-auto -mt-10 relative z-20">
            <div class="bg-white rounded-3xl shadow-premium border border-slate-100 overflow-hidden">
                <!-- Board Header -->
                <div class="px-8 lg:px-12 py-5 bg-white border-b border-slate-50 flex items-center justify-between">
                    <h2 class="text-[12px] font-black text-slate-400 uppercase tracking-widest leading-none">ACTIVE ACADEMIC BULLETINS</h2>
                    <div class="h-2.5 w-2.5 rounded-full bg-green-500 animate-pulse ring-4 ring-green-500/10"></div>
                </div>

                <!-- Notices List -->
                <div class="divide-y divide-slate-100/50">
                    @if (IsLoading)
                    {
                        @for (int i = 0; i < 5; i++)
                        {
                            <div class="p-10 lg:p-14 animate-pulse flex flex-col gap-6">
                                <div class="h-4 w-1/4 bg-slate-50 rounded-full"></div>
                                <div class="h-8 w-3/4 bg-slate-50 rounded-full"></div>
                                <div class="h-4 w-1/2 bg-slate-50 rounded-full"></div>
                            </div>
                        }
                    }
                    else if (NoticeList.Any())
                    {
                        @foreach (var notice in NoticeList)
                        {
                            <div class="p-8 lg:p-12 hover:bg-slate-50 transition-all group relative overflow-hidden">
                                @if (notice.IsUrgent)
                                {
                                    <div class="absolute top-0 right-0">
                                        <div class="bg-red-500 text-white text-[10px] font-black px-8 py-1.5 transform rotate-45 translate-x-10 translate-y-3 uppercase tracking-[0.2em] shadow-xl">URGENT</div>
                                    </div>
                                }
                                
                                <div class="space-y-6 relative z-10">
                                    <div class="flex items-center gap-4">
                                        <div class="flex items-center gap-2">
                                            <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                            <span class="text-[11px] font-black text-primary uppercase tracking-widest">@notice.CreatedOn.ToString("dd MMM yyyy")</span>
                                        </div>
                                        <span class="h-1 w-1 rounded-full bg-slate-200"></span>
                                        <div class="flex items-center gap-2">
                                            <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                                            <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest">RE: INF-@NoticeIdFormat(notice.Id)</span>
                                        </div>
                                    </div>

                                    <h3 class="text-2xl font-black text-slate-900 group-hover:text-primary transition-all uppercase leading-tight tracking-tight">@notice.Title</h3>
                                    
                                    <p class="text-slate-500 font-bold leading-relaxed text-[14px] lg:text-[16px] max-w-4xl uppercase tracking-tight">
                                        @notice.Content
                                    </p>
                                </div>      
                                
                                @if (!string.IsNullOrEmpty(notice.LinkUrl))
                                {
                                    <div class="pt-8 relative z-10">
                                        <a href="@notice.LinkUrl" target="_blank" class="inline-flex items-center gap-3 px-6 py-3 bg-slate-950 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-primary hover:shadow-xl transition-all shadow-premium active:scale-95 leading-none">
                                            DOWNLOAD ATTACHMENT
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                                        </a>
                                    </div>
                                }
                                
                                <!-- Subtle Glow for Urgent -->
                                @if (notice.IsUrgent)
                                {
                                    <div class="absolute inset-0 bg-red-500/[0.03] pointer-events-none transition-colors group-hover:bg-red-500/[0.05]"></div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="py-48 text-center space-y-8">
                            <div class="h-24 w-24 bg-slate-50 rounded-3xl flex items-center justify-center text-slate-200 mx-auto shadow-inner">
                                <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            </div>
                            <p class="text-slate-400 font-black uppercase tracking-widest text-[14px] max-w-sm mx-auto leading-relaxed">The registry is currently processing new digital bulletins. Check back shortly.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>


@code {
    private List<CampusNotice> NoticeList { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            NoticeList = await NoticeService.GetActiveNoticesAsync();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string NoticeIdFormat(long id) => id.ToString("D4");
}
