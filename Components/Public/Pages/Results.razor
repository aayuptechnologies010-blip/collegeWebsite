@page "/results"
@using CollegeWebSite.Components.Public.Layout
@using CollegeWebSite.Components.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout MainLayout
@inject IResultService ResultService

<SeoHead Title="Examination Results | Ishika Nursing & Paramedical Studies"
         Description="View examination results for Ishika Nursing & Paramedical College students — secure lookup by roll number and exam."
         Keywords="Ishika nursing results, GNM exam results Kendujhar, student result portal Odisha" />

<!-- Premium Hero Section -->
<section class="relative py-12 lg:py-16 bg-primary overflow-hidden">
    <!-- Dynamic Background Elements -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none">
        <div class="absolute top-[-10%] left-[-10%] w-[50rem] h-[50rem] bg-primary/20 rounded-full blur-[120px] animate-pulse"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[50rem] h-[50rem] bg-secondary/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s"></div>
    </div>
    
    <div class="container-custom relative z-10">
        <div class="max-w-4xl mx-auto text-center space-y-10">
            <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md animate-in fade-in slide-in-from-bottom-4 duration-700">
                <span class="flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                </span>
                <span class="text-[10px] font-black text-white uppercase tracking-widest">INSTITUTIONAL RESULT REGISTRY</span>
            </div>
            
            <h1 class="text-3xl lg:text-5xl font-black text-white leading-tight uppercase tracking-tight animate-in fade-in slide-in-from-bottom-8 duration-700 delay-100">
                Academic <br />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-white to-secondary italic">Performance Statement.</span>
            </h1>
            
            <p class="text-slate-400 font-bold text-[14px] lg:text-[16px] max-w-2xl mx-auto leading-relaxed animate-in fade-in slide-in-from-bottom-12 duration-700 delay-200 uppercase tracking-tight">
                Securely access your official examination scores and marks-sheets from the Ishika Institutional Registry.
            </p>
        </div>
    </div>

    <!-- Decorative Wave -->
    <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-white to-transparent"></div>
</section>

<!-- Main Portal Section -->
<section class="pb-24 lg:pb-32 bg-white relative -mt-8 z-20">
    <div class="container-custom">
        <div class="max-w-5xl mx-auto">
            
            @if (Result == null)
            {
                <!-- Enhanced Inquiry Form -->
                <div class="bg-white rounded-3xl p-10 lg:p-14 shadow-premium border border-slate-100">
                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
                        <!-- Form Area -->
                        <div class="lg:col-span-7 space-y-8 lg:space-y-10">
                            <div class="space-y-4">
                                <h3 class="text-2xl lg:text-3xl font-black text-slate-900 tracking-tight uppercase leading-none">Credential Verification</h3>
                                <p class="text-slate-500 font-bold text-[13px] lg:text-[14px] leading-relaxed uppercase tracking-tight">Enter your institutional credentials to fetch the report.</p>
                            </div>

                            <form @onsubmit="FetchResult" class="space-y-8">
                                <div class="grid grid-cols-1 gap-6">
                                    <div class="group space-y-3">
                                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-2">TARGET EXAMINATION</label>
                                        <div class="relative">
                                            <select @bind="SelectedExam" class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl text-slate-900 font-black focus:border-primary/20 focus:bg-white transition-all outline-none appearance-none cursor-pointer text-[14px] uppercase shadow-sm">
                                                <option value="">-- Choose Exam --</option>
                                                @foreach (var exam in AvailableExams)
                                                {
                                                    <option value="@exam">@exam</option>
                                                }
                                            </select>
                                            <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M19 9l-7 7-7-7" /></svg>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="group space-y-3">
                                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-2">ROLL IDENTIFIER</label>
                                        <input type="text" @bind="RollNumber" placeholder="ISH2024001" 
                                               class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl text-slate-900 font-black placeholder:text-slate-300 focus:border-primary/20 focus:bg-white transition-all outline-none uppercase text-[14px] shadow-sm" />
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(ErrorMessage))
                                {
                                    <div class="flex items-center gap-4 px-8 py-5 bg-red-50 text-red-600 rounded-2xl border border-red-100 animate-in fade-in slide-in-from-top-2">
                                        <svg class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                                        <p class="text-[14px] font-bold">@ErrorMessage</p>
                                    </div>
                                }

                                <button type="submit" disabled="@IsSearching" 
                                        class="group/btn relative w-full py-4.5 bg-primary text-white font-black rounded-2xl overflow-hidden shadow-premium border border-white/10 hover:shadow-2xl hover:-translate-y-1 transition-all active:scale-95 disabled:opacity-50">
                                    <div class="relative z-10 flex items-center justify-center gap-3">
                                        @if (IsSearching)
                                        {
                                            <div class="w-5 h-5 border-3 border-white/30 border-t-white rounded-full animate-spin"></div>
                                            <span class="uppercase tracking-widest text-[12px]">AUTHENTICATING...</span>
                                        }
                                        else
                                        {
                                            <span class="uppercase tracking-widest text-[12px]">GENERATE DIGITAL REPORT</span>
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                                        }
                                    </div>
                                </button>
                            </form>
                        </div>

                        <!-- Sidebar Info -->
                        <div class="lg:col-span-5 flex flex-col justify-between py-4 border-l border-slate-100 pl-12">
                             <div class="space-y-10">
                                 <div class="flex gap-6">
                                    <div class="h-14 w-14 shrink-0 bg-primary/5 rounded-2xl text-primary flex items-center justify-center border border-primary/10 shadow-sm">
                                        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                                    </div>
                                    <div class="space-y-2">
                                        <h4 class="text-[15px] font-black text-slate-900 uppercase">Secure Encryption</h4>
                                        <p class="text-[12px] text-slate-500 font-bold leading-relaxed uppercase tracking-tight">Academic data is transmitted over a secure, institutional encrypted channel.</p>
                                    </div>
                                 </div>

                                 <div class="flex gap-6">
                                    <div class="h-14 w-14 shrink-0 bg-secondary/5 rounded-2xl text-secondary flex items-center justify-center border border-secondary/10 shadow-sm">
                                        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
                                    </div>
                                    <div class="space-y-2">
                                        <h4 class="text-[15px] font-black text-slate-900 uppercase">ONMRC Certified</h4>
                                        <p class="text-[12px] text-slate-500 font-bold leading-relaxed uppercase tracking-tight">Verified alignment with Odisha Nursing Management & Examination Board standards.</p>
                                    </div>
                                 </div>
                             </div>

                             <div class="bg-slate-50 rounded-3xl p-6 border border-slate-100 flex items-center gap-6 mt-12">
                                 <div class="shrink-0 h-12 w-12 rounded-full bg-white flex items-center justify-center shadow-sm">
                                     <svg class="w-6 h-6 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z"/></svg>
                                 </div>
                                 <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-relaxed italic">
                                     Institutional results are updated every <span class="text-slate-900">24 business hours</span> during examination cycles.
                                 </p>
                             </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Ultra-Premium Result Display -->
                <div class="animate-in zoom-in-95 duration-1000">
                    <div class="bg-white rounded-3xl overflow-hidden shadow-2xl border border-slate-100 relative group">
                        
                        <!-- Header Banner -->
                        <div class="bg-primary p-8 lg:p-10 text-white relative overflow-hidden">
                            <div class="absolute inset-0 bg-gradient-to-br from-primary/30 to-transparent opacity-60 pointer-events-none"></div>
                            
                            <div class="relative z-10 flex flex-col lg:flex-row justify-between items-center gap-8 text-center lg:text-left">
                                <div class="space-y-2">
                                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 text-white rounded-full text-[9px] font-black uppercase tracking-widest border border-white/10">INSTITUTIONAL ACADEMIC REPORT</div>
                                    <h2 class="text-3xl lg:text-4xl font-black leading-tight tracking-tighter uppercase">Performance <span class="text-primary-light italic">Statement.</span></h2>
                                    <p class="text-white/60 font-bold text-[10px] lg:text-[11px] uppercase tracking-widest">RECORD ID: IST-@Result.Id | ISSUED: @DateTime.UtcNow.ToString("dd MMM yyyy")</p>
                                </div>
                                <button @onclick="() => Result = null" class="group/btn px-8 py-3 bg-white text-slate-900 font-black text-[12px] uppercase tracking-widest rounded-2xl shadow-xl hover:bg-primary-light hover:text-primary transition-all flex items-center gap-3">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
                                    Verify Another
                                </button>
                            </div>
                        </div>

                        <!-- Content Area -->
                        <div class="p-8 lg:p-16 space-y-12">
                            <!-- Student Metadata -->
                            <div class="flex flex-col lg:grid lg:grid-cols-12 gap-12 items-start">
                                <div class="lg:col-span-8 space-y-6">
                                    <div class="space-y-2">
                                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">FULL LEGAL NAME</p>
                                        <h3 class="text-3xl lg:text-5xl font-black text-slate-900 tracking-tighter uppercase leading-none">@Result.StudentName</h3>
                                    </div>
                                    
                                    <div class="grid grid-cols-2 lg:grid-cols-3 gap-10">
                                        <div class="space-y-1">
                                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">TARGET COURSE</p>
                                            <p class="text-[16px] font-black text-slate-700 uppercase">@Result.Course</p>
                                        </div>
                                        <div class="space-y-1">
                                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">BATCH</p>
                                            <p class="text-[16px] font-black text-slate-700 uppercase">@Result.Batch</p>
                                        </div>
                                        <div class="space-y-1">
                                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">IDENTIFIER</p>
                                            <p class="text-[16px] font-black text-slate-700 uppercase">@Result.RollNumber</p>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="lg:col-span-4 lg:text-right space-y-4 w-full lg:w-auto">
                                    <div class="inline-block p-6 bg-slate-50 rounded-3xl border border-slate-100 text-center lg:text-right w-full lg:w-auto shadow-sm">
                                         <p class="text-[9px] font-black text-primary uppercase tracking-widest mb-1.5">EXAMINATION</p>
                                         <p class="text-xl font-black text-slate-900 leading-none uppercase">@Result.ExamName</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Performance Stats -->
                            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                                <div class="group/card relative h-40 bg-slate-50 rounded-3xl p-8 flex flex-col items-center justify-center transition-all hover:bg-white hover:shadow-premium">
                                     <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest relative z-10 group-hover/card:text-primary mb-2">MASTER GRADE</p>
                                     <p class="text-6xl font-black text-primary relative z-10 transition-transform group-hover/card:scale-110">@Result.Grade</p>
                                </div>
                                
                                <div class="group/card relative h-40 bg-slate-50 rounded-3xl p-8 flex flex-col items-center justify-center transition-all hover:bg-white hover:shadow-premium">
                                     <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest relative z-10 group-hover/card:text-secondary mb-2">AGGREGATE SCORE</p>
                                     <div class="flex items-baseline gap-2 relative z-10 transition-transform group-hover/card:scale-110">
                                         <p class="text-6xl font-black text-slate-900">@Result.TotalPercentage</p>
                                         <span class="text-2xl font-black text-slate-300">%</span>
                                     </div>
                                </div>

                                <div class="group/card relative h-40 @(Result.ResultStatus == "Pass" ? "bg-green-50 text-green-600" : "bg-red-50 text-red-600") rounded-3xl p-8 flex flex-col items-center justify-center transition-all hover:bg-white hover:shadow-premium">
                                     <p class="text-[10px] font-black uppercase tracking-widest relative z-10 opacity-60 mb-2">STATUS OUTCOME</p>
                                     <p class="text-4xl font-black uppercase tracking-widest relative z-10 transition-transform group-hover/card:scale-110">@Result.ResultStatus</p>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Result.Remarks))
                            {
                                <div class="relative p-8 rounded-3xl bg-slate-900 text-white overflow-hidden group/remarks shadow-xl">
                                    <div class="absolute inset-0 bg-gradient-to-r from-primary/20 to-transparent pointer-events-none"></div>
                                    <div class="flex gap-6 relative z-10">
                                        <div class="shrink-0 h-12 w-12 rounded-2xl bg-white/10 flex items-center justify-center text-primary-light">
                                            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" /></svg>
                                        </div>
                                        <div class="space-y-2">
                                            <h4 class="text-[9px] font-black uppercase tracking-widest text-primary-light opacity-60">INSTITUTIONAL ASSESSMENT</h4>
                                            <p class="text-[16px] lg:text-[18px] font-bold leading-relaxed italic pr-12 uppercase tracking-tight">"@Result.Remarks"</p>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Dynamic Action Footer -->
                            <div class="pt-10 border-t border-slate-100 flex flex-col lg:flex-row gap-8 items-center justify-between">
                                <div class="flex items-center gap-4">
                                     <div class="h-12 w-12 rounded-2xl border border-slate-100 p-1 shadow-sm">
                                         <div class="h-full w-full rounded-xl bg-slate-50 flex items-center justify-center text-slate-300">
                                             <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M9 12l2 2 4-4" /></svg>
                                         </div>
                                     </div>
                                     <div class="text-[11px] text-slate-400 font-black uppercase leading-tight">
                                         SYSTEM ID: <span class="text-slate-900">SEC-@Result.Id.ToString("000000")</span> <br />
                                         CRYPTOGRAPHICALLY SIGNED & VERIFIED BY REGISTRY.
                                     </div>
                                </div>
                                
                                <div class="flex flex-wrap justify-center gap-4">
                                     <button onclick="window.print()" class="px-8 py-3.5 bg-slate-100 text-slate-900 font-black text-[11px] uppercase tracking-widest rounded-2xl hover:bg-slate-200 transition-all flex items-center gap-3 shadow-sm">
                                         <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
                                         Print Statement
                                     </button>
                                     @if (!string.IsNullOrEmpty(Result.DownloadUrl))
                                     {
                                         <a href="@Result.DownloadUrl" class="px-8 py-3.5 bg-primary text-white font-black text-[11px] uppercase tracking-widest rounded-2xl shadow-premium border border-white/10 hover:shadow-2xl hover:-translate-y-1 transition-all flex items-center gap-3">
                                             <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                                             Digital Vault
                                         </a>
                                     }
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Bottom Branding -->
                    <div class="mt-20 text-center space-y-4 opacity-30">
                         <p class="text-[11px] font-black uppercase tracking-[0.5em] text-slate-900">Ishika Nursing & Paramedical Studies</p>
                         <div class="w-16 h-[3px] bg-slate-900 mx-auto rounded-full"></div>
                    </div>
                </div>
            }

        </div>
    </div>
</section>

<style>
    @@media print {
        header, footer, .NoticeTicker, .bg-slate-950, button, .group/btn { display: none !important; }
        .pb-32 { padding: 0 !important; margin: 0 !important; }
        .container-custom { max-width: 100% !important; padding: 0 !important; }
        .max-w-5xl { max-width: 100% !important; }
        .shadow-premium, .shadow-2xl, .shadow-xl { box-shadow: none !important; }
        .rounded-[4rem], .rounded-[3.5rem], .rounded-[3rem] { border-radius: 0 !important; border: 1px solid #eee !important; }
        .bg-white { background: white !important; }
        .text-slate-900 { color: black !important; }
    }
</style>

@code {
    private List<string> AvailableExams { get; set; } = new();
    private string SelectedExam { get; set; } = "";
    private string RollNumber { get; set; } = "";
    private string ErrorMessage { get; set; } = "";
    private bool IsSearching { get; set; } = false;
    private StudentResult? Result { get; set; }

    protected override async Task OnInitializedAsync()
    {
        AvailableExams = await ResultService.GetAvailableExamsAsync();
    }

    private async Task FetchResult()
    {
        if (string.IsNullOrEmpty(SelectedExam) || string.IsNullOrEmpty(RollNumber))
        {
            ErrorMessage = "Please fill in all credentials.";
            return;
        }

        IsSearching = true;
        ErrorMessage = "";
        
        try 
        {
            await Task.Delay(1200); // Premium delay for "processing" feel
            Result = await ResultService.GetResultByRollNumberAsync(RollNumber.Trim(), SelectedExam);
            
            if (Result == null)
            {
                ErrorMessage = "Record not found. Please verify your Roll Number and targeted Examination.";
            }
        }
        finally
        {
            IsSearching = false;
        }
    }
}
