@page "/placements"
@using CollegeWebSite.Components.Public.Layout
@using CollegeWebSite.Components.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout MainLayout
@inject IPlacementService PlacementService

<SeoHead Title="Placements & Careers | Ishika Nursing & Paramedical Studies"
         Description="Placement support and career outcomes for Ishika Nursing graduates — hospitals, clinics, and healthcare employers across Odisha and India."
         Keywords="nursing placement Odisha, Ishika alumni jobs, GNM hospital placement Kendujhar, nursing career support" />

<!-- Success Stasts Hero -->
<section class="relative py-16 lg:py-24 bg-slate-900 overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[60rem] h-[60rem] bg-primary/10 rounded-full blur-[120px] -z-0"></div>
    
    <div class="container-custom relative z-10">
        <div class="max-w-4xl mx-auto text-center space-y-8 animate-parallax">
            <h1 class="text-3xl lg:text-5xl font-black text-white leading-tight uppercase tracking-tight">
                Our Alumni <br />
                <span class="text-primary-light italic">Global Impact.</span>
            </h1>
            
            <!-- Key Stats -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 pt-10">
                <div class="p-6 lg:p-8 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md shadow-premium">
                    <div class="text-3xl lg:text-4xl font-black text-white mb-2">100%</div>
                    <div class="text-[9px] lg:text-[10px] font-black text-slate-400 uppercase tracking-widest">Placement Assist</div>
                </div>
                <div class="p-6 lg:p-8 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md shadow-premium">
                    <div class="text-3xl lg:text-4xl font-black text-white mb-2">500+</div>
                    <div class="text-[9px] lg:text-[10px] font-black text-slate-400 uppercase tracking-widest">Global Alumni</div>
                </div>
                <div class="p-6 lg:p-8 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md shadow-premium">
                    <div class="text-3xl lg:text-4xl font-black text-white mb-2">50+</div>
                    <div class="text-[9px] lg:text-[10px] font-black text-slate-400 uppercase tracking-widest">Hospital Partners</div>
                </div>
                <div class="p-6 lg:p-8 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md shadow-premium">
                    <div class="text-3xl lg:text-4xl font-black text-white mb-2">4.5L</div>
                    <div class="text-[9px] lg:text-[10px] font-black text-slate-400 uppercase tracking-widest">Highest Package</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Partner Hospitals -->
<section class="py-12 lg:py-20 bg-white border-b border-slate-100">
    <div class="container-custom">
        <div class="flex flex-wrap items-center justify-center gap-8 lg:gap-20 opacity-30 grayscale hover:grayscale-0 transition-all duration-700">
            <span class="text-2xl lg:text-3xl font-black text-slate-900 tracking-tighter">APOLLO</span>
            <span class="text-2xl lg:text-3xl font-black text-slate-900 tracking-tighter">AMRI</span>
            <span class="text-2xl lg:text-3xl font-black text-slate-900 tracking-tighter">FORTIS</span>
            <span class="text-2xl lg:text-3xl font-black text-slate-900 tracking-tighter">CARE</span>
            <span class="text-2xl lg:text-3xl font-black text-slate-900 tracking-tighter">AIIMS</span>
        </div>
    </div>
</section>

<!-- Success Stories Grid -->
<section class="py-24 lg:py-32 bg-slate-50 relative overflow-hidden">
    <div class="container-custom relative z-10">
        <div class="text-center mb-16 lg:mb-24 space-y-4">
             <h2 class="text-3xl lg:text-4xl font-black text-slate-900 uppercase tracking-tight">Career <span class="text-primary italic">Milestones.</span></h2>
             <p class="text-slate-500 max-w-2xl mx-auto font-bold text-[14px] lg:text-[16px] leading-relaxed uppercase tracking-tight">Hear from our students who transitioned from clinical excellence in our labs to specialized departments across the nation.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
            @if (IsLoading)
            {
                @for(int i=0; i<3; i++)
                {
                    <div class="h-80 bg-white rounded-3xl animate-pulse"></div>
                }
            }
            else
            {
                @foreach (var record in SuccessStories)
                {
                    <div class="group relative bg-white p-10 lg:p-12 rounded-3xl border border-slate-100 shadow-premium hover:shadow-2xl transition-all group duration-500 flex flex-col items-center text-center">
                        <!-- Student Photo -->
                        <div class="relative mb-8">
                            <div class="h-24 w-24 lg:h-32 lg:w-32 rounded-full overflow-hidden border-4 border-white shadow-xl group-hover:shadow-primary-light/30 transition-shadow">
                                <OptimizedImage Media="@record.StudentPhoto" 
                                                Src="@(record.StudentPhoto == null ? "images/placeholder-avatar.jpg" : null)"
                                                AltText="@record.StudentName"
                                                Class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110" />
                            </div>
                            <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 px-4 py-1 bg-slate-950 text-white text-[9px] font-black uppercase tracking-widest rounded-full shadow-lg border border-white/20">
                                BATCH OF @record.Batch
                            </div>
                        </div>

                        <!-- Info -->
                        <div class="space-y-4 w-full">
                            <div class="space-y-1">
                                <h4 class="text-xl lg:text-2xl font-black text-slate-900 uppercase leading-none tracking-tight">@record.StudentName</h4>
                                <p class="text-[11px] font-black text-primary uppercase tracking-widest group-hover:text-primary-light transition-all">@record.HospitalName</p>
                            </div>
                            <p class="text-slate-500 font-bold italic leading-relaxed text-[13px] lg:text-[14px] line-clamp-4 uppercase tracking-tight">
                                "@record.Testimonial"
                            </p>

                            <div class="pt-6 mt-4 border-t border-slate-50">
                                <span class="px-3 py-1 rounded-full bg-slate-50 text-slate-400 text-[10px] font-black uppercase tracking-[0.1em] leading-none">
                                    @record.Designation • @record.Course
                                </span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- Final CTA -->
<section class="py-12 lg:py-24 bg-white">
    <div class="container-custom">
        <div class="bg-primary rounded-3xl p-10 lg:p-16 relative overflow-hidden text-center lg:text-left lg:flex items-center justify-between gap-12 shadow-premium">
            <div class="absolute bottom-0 right-0 w-[40rem] h-[40rem] bg-white/10 rounded-full blur-[120px] translate-x-1/3 translate-y-1/3"></div>
            
            <div class="relative z-10 max-w-2xl space-y-4">
                <h2 class="text-3xl lg:text-4xl font-black text-white leading-tight uppercase tracking-tight">
                    Start Your Global <br /> <span class="text-primary-light italic">Success Story.</span>
                </h2>
                <p class="text-white/80 font-bold text-[14px] lg:text-[16px] uppercase tracking-tight">
                    With our dedicated 100% placement support program, your elite healthcare career starts from day one.
                </p>
            </div>

            <div class="relative z-10 mt-10 lg:mt-0 shrink-0">
                <a href="/apply" class="px-10 py-5 bg-white text-primary font-black text-[12px] rounded-2xl hover:bg-slate-950 hover:text-white transition-all shadow-xl flex items-center justify-center gap-3 active:scale-95 uppercase tracking-widest">
                    SECURE YOUR FUTURE
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </a>
            </div>
        </div>
    </div>
</section>


@code {
    private List<PlacementRecord> SuccessStories { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            SuccessStories = await PlacementService.GetAllPlacementsAsync();
        }
        finally
        {
            IsLoading = false;
        }
    }
}
