@page "/events"
@using CollegeWebSite.Components.Public.Layout
@using CollegeWebSite.Components.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout MainLayout
@inject IEventService EventService

<SeoHead Title="Campus Events & News | Ishika Nursing & Paramedical Studies"
         Description="Workshops, seminars, health camps, and campus events at Ishika Nursing & Paramedical College, Kendujhar — stay updated with our calendar."
         Keywords="Ishika nursing events, Kendujhar college seminars, nursing college workshops Odisha, campus news Ishika" />

@inject ISeoService SeoService
@foreach(var ev in CampusEvents)
{
    <StructuredData JsonLd="@SeoService.GenerateEventSchema(ev)" />
}

<!-- Master Header -->
<section class="relative py-8 lg:py-12 bg-white overflow-hidden">
    <div class="absolute top-0 right-0 w-[40rem] h-[40rem] bg-primary/5 rounded-full blur-[100px] -z-0"></div>
    <div class="container-custom relative z-10">
        <div class="max-w-3xl space-y-2">
            <span class="inline-block px-1.5 py-0.5 rounded bg-primary/5 text-primary text-[8px] font-black uppercase tracking-widest">
                Life at Ishika
            </span>
            <h1 class="text-xl lg:text-2xl font-black text-slate-900 leading-tight uppercase">
                Institutional <br />
                <span class="text-secondary italic">Highlights.</span>
            </h1>
            <p class="text-slate-500 font-bold text-[11px] lg:text-[12px] leading-relaxed max-w-2xl uppercase tracking-tighter">
                From national seminars to community health camps, explore how our students are shaping the future of healthcare.
            </p>
        </div>
    </div>
</section>

<!-- Filter & Feed -->
<section class="pb-12 lg:pb-24 bg-white">
    <div class="container-custom">
        <!-- Upcoming Spotlight -->
        <h2 class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-4 border-b border-slate-100 pb-2">Upcoming Engagements</h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            @if (IsLoading)
            {
                <div class="lg:col-span-12 h-64 bg-slate-50 rounded-xl animate-pulse"></div>
            }
            else if (CampusEvents.Any())
            {
                @foreach (var ev in CampusEvents)
                {
                    <div class="lg:col-span-12 group">
                        <div class="relative bg-white rounded overflow-hidden border border-slate-100 shadow-sm transition-all group duration-500 flex flex-col lg:flex-row">
                             <!-- Image Section -->
                             <div class="lg:w-1/3 aspect-video lg:aspect-auto relative overflow-hidden">
                                 <img src="@(ev.Banner?.Url ?? "images/placeholder-event.jpg")" alt="@ev.Title" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                                 <div class="absolute top-4 left-4">
                                     <div class="px-2 py-1.5 bg-white shadow-xl border border-slate-100 text-center rounded">
                                         <span class="block text-base font-black text-slate-900 leading-none">@ev.EventDate.Day</span>
                                         <span class="block text-[7px] font-black text-primary uppercase tracking-widest mt-0.5">@ev.EventDate.ToString("MMM")</span>
                                     </div>
                                 </div>
                             </div>

                              <!-- Content Section -->
                              <div class="lg:w-2/3 p-5 lg:p-7 flex flex-col justify-center space-y-3">
                                 <div class="space-y-1">
                                     <div class="flex items-center gap-1.5 text-secondary font-black text-[8px] uppercase tracking-widest">
                                         <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                         @ev.Venue
                                     </div>
                                     <h3 class="text-lg font-black text-slate-900 leading-tight group-hover:text-primary transition-colors uppercase">@ev.Title</h3>
                                     <p class="text-slate-500 font-bold text-[11px] lg:text-[12px] leading-relaxed line-clamp-2 uppercase tracking-tighter">@ev.Description</p>
                                 </div>

                                 <div class="pt-3 border-t border-slate-50 flex items-center justify-between">
                                     <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest">
                                         @ev.EventDate.ToString("hh:mm tt")
                                     </span>
                                     <button class="flex items-center gap-1 text-primary font-black text-[9px] uppercase tracking-widest group/btn">
                                         Details
                                         <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                                     </button>
                                 </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="lg:col-span-12 py-32 text-center space-y-4">
                    <div class="h-20 w-20 bg-slate-50 rounded-[2rem] flex items-center justify-center mx-auto text-slate-300">
                        <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                    <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">No upcoming events scheduled at this moment.</p>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private List<CollegeWebSite.Domain.Entities.Event> CampusEvents { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            CampusEvents = await EventService.GetAllEventsAsync(true);
        }
        finally
        {
            IsLoading = false;
        }
    }
}
