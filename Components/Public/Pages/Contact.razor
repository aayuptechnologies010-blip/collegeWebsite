@page "/p/contact"
@using CollegeWebSite.Components.Public.Layout
@using CollegeWebSite.Components.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@using Microsoft.Extensions.Options
@using CollegeWebSite.Domain.Settings
@layout MainLayout
@inject IInquiryService InquiryService
@inject NavigationManager NavManager
@inject IOptions<InstitutionSettings> InstitutionOptions

<SeoHead Title="Contact Us | Ishika Nursing & Paramedical Studies"
         Description="Contact Ishika Nursing & Paramedical College in Kendujhar, Odisha — phone, email, campus address, and directions for admissions and enquiries."
         Keywords="Ishika Nursing contact, Kendujhar nursing college phone, nursing college Odisha address, Ishika admissions contact"
         CanonicalUrl="/p/contact" />

<!-- Page Header -->
<section class="relative py-16 lg:py-24 bg-primary overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 pointer-events-none"></div>
    <!-- Sophisticated Blobs -->
    <div class="absolute top-[-10%] left-[-10%] w-[50rem] h-[50rem] bg-primary-light/10 rounded-full blur-[120px] animate-blob"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[45rem] h-[45rem] bg-secondary/10 rounded-full blur-[100px] animate-blob" style="animation-delay: 3s"></div>

    <div class="container-custom relative z-10 text-center">
        <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white text-[10px] font-black uppercase tracking-widest border border-white/10 mb-6 leading-none">
            GET IN TOUCH
        </span>
        <h1 class="text-3xl lg:text-4xl font-black text-white leading-tight uppercase">
            We're Here <span class="text-white italic">to Help.</span>
        </h1>
        <p class="text-slate-100/70 font-bold text-[14px] lg:text-[16px] max-w-2xl mx-auto mt-4 leading-relaxed uppercase tracking-tight">
            Have questions about admissions, fees, or our campus? Reach out to our dedicated support team for immediate assistance.
        </p>
    </div>
</section>

<section class="py-20 lg:py-32 bg-slate-50 relative overflow-hidden">
    <div class="container-custom relative z-10">
        <div class="flex flex-col lg:grid lg:grid-cols-12 gap-16 lg:gap-24 items-start">
            
            <!-- Side Contact Card -->
            <div class="lg:col-span-5 space-y-6">
                <div class="grid grid-cols-1 gap-4">
                    <!-- Address -->
                    <div class="bg-white p-5 lg:p-6 rounded-2xl shadow-glass border border-slate-100 flex gap-4 group hover:border-primary transition-all duration-500">
                        <div class="h-12 w-12 rounded-xl bg-primary-light text-primary flex items-center justify-center shrink-0 shadow-sm group-hover:bg-primary group-hover:text-white transition-all">
                             <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <div>
                            <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Campus Location</h4>
                            <p class="text-[13px] font-bold text-slate-950 leading-relaxed uppercase tracking-tight">@InstitutionOptions.Value.Contact.Address</p>
                        </div>
                    </div>

                    <!-- Phone -->
                    <div class="bg-white p-5 lg:p-6 rounded-2xl shadow-glass border border-slate-100 flex gap-4 group hover:border-secondary transition-all duration-500">
                        <div class="h-12 w-12 rounded-xl bg-secondary-light text-secondary flex items-center justify-center shrink-0 shadow-sm group-hover:bg-secondary group-hover:text-white transition-all">
                             <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        </div>
                        <div>
                             <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Call Support</h4>
                             <p class="text-[13px] font-black text-slate-950 leading-tight tracking-widest">@InstitutionOptions.Value.Contact.Phone</p>
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="bg-white p-5 lg:p-6 rounded-2xl shadow-glass border border-slate-100 flex gap-4 group hover:border-accent transition-all duration-500">
                        <div class="h-12 w-12 rounded-xl bg-accent/5 text-accent flex items-center justify-center shrink-0 shadow-sm group-hover:bg-accent group-hover:text-white transition-all">
                             <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        </div>
                        <div>
                             <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Email Us</h4>
                             <p class="text-[13px] font-bold text-slate-950 leading-tight uppercase tracking-tight">@InstitutionOptions.Value.Contact.Email.ToUpper()</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Interactive Message Form -->
            <div class="lg:col-span-7 w-full">
                @if (IsSubmitted)
                {
                    <div class="bg-white rounded-3xl p-16 lg:p-24 shadow-premium border border-slate-100 text-center space-y-6">
                        <div class="h-24 w-24 bg-primary/20 text-primary rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-inner">
                             <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        </div>
                        <h2 class="text-3xl font-black text-slate-900 uppercase">Message Sent</h2>
                        <p class="text-[14px] text-slate-500 font-bold max-w-sm mx-auto uppercase leading-relaxed">We've received your query. A campus representative will get back to you within 24 hours.</p>
                        <button @onclick="ResetForm" class="px-10 py-4 bg-slate-950 text-white font-black rounded-2xl shadow-xl hover:bg-primary transition-all uppercase text-[12px] tracking-widest">Send Another</button>
                    </div>
                }
                else
                {
                    <div class="bg-white rounded-3xl p-10 lg:p-14 shadow-premium">
                        <h3 class="text-2xl font-black text-slate-900 mb-8 flex items-center gap-3 uppercase tracking-tight leading-none">
                             Send Message
                             <div class="h-1 w-6 rounded-full bg-secondary"></div>
                        </h3>
                        
                        <EditForm Model="Message" OnValidSubmit="HandleSubmit" FormName="ContactInquiry" class="space-y-6">
                            <DataAnnotationsValidator />
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Full Name</label>
                                    <InputText @bind-Value="Message.Name" class="w-full px-5 py-4 bg-slate-50 rounded-2xl border border-slate-100 focus:bg-white focus:border-primary transition-all text-[14px] font-bold uppercase" placeholder="RAHUL KHANNA..." />
                                    <ValidationMessage For="@(() => Message.Name)" class="text-[10px] text-red-500 mt-1 font-bold" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Email Address</label>
                                    <InputText @bind-Value="Message.Email" type="email" class="w-full px-5 py-4 bg-slate-50 rounded-2xl border border-slate-100 focus:bg-white focus:border-primary transition-all text-[14px] font-bold uppercase" placeholder="YOUR@EMAIL.COM" />
                                    <ValidationMessage For="@(() => Message.Email)" class="text-[10px] text-red-500 mt-1 font-bold" />
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Message Body</label>
                                <InputTextArea @bind-Value="Message.Message" rows="5" class="w-full px-5 py-4 bg-slate-50 rounded-2xl border border-slate-100 focus:bg-white focus:border-primary transition-all text-[14px] font-bold uppercase" placeholder="DESCRIBE YOUR INQUIRY..."></InputTextArea>
                                <ValidationMessage For="@(() => Message.Message)" class="text-[10px] text-red-500 mt-1 font-bold" />
                            </div>
                            <button type="submit" disabled="@IsSubmitting" class="w-full py-5 bg-primary text-white font-black rounded-2xl hover:opacity-95 transition-all shadow-premium active:scale-[0.98] flex items-center justify-center gap-3 disabled:opacity-50 text-[12px] uppercase tracking-widest leading-none">
                                @if (IsSubmitting)
                                {
                                    <span class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                                    <span>SENDING INQUIRY...</span>
                                }
                                else
                                {
                                    <span>SEND MESSAGE</span>
                                }
                            </button>
                        </EditForm>
                    </div>
                }
            </div>

        </div>
    </div>
</section>

<!-- Full Width Map Section -->
<section class="bg-white border-t border-slate-100 relative group overflow-hidden">

    <!-- Address Info Card (top-left overlay) -->
    <div class="absolute top-6 left-6 z-20 max-w-xs hidden lg:block">
        <div class="bg-white rounded-2xl shadow-2xl border border-slate-100 p-5 space-y-3">
            <div class="flex items-center gap-2 mb-1">
                <div class="h-8 w-8 rounded-xl bg-primary flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">Campus Location</span>
            </div>
            <p class="text-[12px] font-bold text-slate-800 leading-relaxed uppercase tracking-tight">DD College Road, Harihar Colony, Baniapat, Keonjhar &ndash; 758001, Odisha</p>
            <div class="flex flex-col gap-2 pt-1">
                <a href="tel:+916370295569" class="flex items-center gap-2 text-[11px] font-black text-slate-600 hover:text-primary transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    +91 6370295569
                </a>
                <a href="mailto:info.ishikanursing@gmail.com" class="flex items-center gap-2 text-[11px] font-black text-slate-600 hover:text-primary transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    info.ishikanursing@gmail.com
                </a>
            </div>
            <a href="@InstitutionOptions.Value.Contact.NavigationUrl" target="_blank" class="mt-2 w-full py-2.5 bg-primary text-white rounded-xl flex items-center justify-center gap-2 font-black uppercase text-[10px] tracking-widest hover:opacity-90 transition-all">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7l5-2.5 5.553 2.776a1 1 0 01.447.894v10.764a1 1 0 01-1.447.894L14 17l-5 3z"/></svg>
                Get Directions
            </a>
        </div>
    </div>

    <!-- Mobile Navigation Overlay (Always Visible on Small Screens) -->
    <div class="lg:hidden absolute bottom-6 left-1/2 -translate-x-1/2 z-20 w-full px-6">
        <a href="@InstitutionOptions.Value.Contact.NavigationUrl" target="_blank" class="w-full py-4 bg-primary text-white rounded-2xl shadow-2xl flex items-center justify-center gap-3 font-black uppercase text-[11px] tracking-widest">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7l5-2.5 5.553 2.776a1 1 0 01.447.894v10.764a1 1 0 01-1.447.894L14 17l-5 3z"/></svg>
            Open Navigation
        </a>
    </div>

    <div class="h-[450px] lg:h-[650px] w-full">
        <iframe 
            width="100%" 
            height="100%" 
            frameborder="0" 
            scrolling="no" 
            marginheight="0" 
            marginwidth="0" 
            src="@InstitutionOptions.Value.Contact.GoogleMapsUrl"
            style="filter: contrast(1.1) brightness(1.05);">
        </iframe>
    </div>
</section>

@code {
    private Inquiry Message { get; set; } = new();
    private bool IsSubmitted { get; set; } = false;
    private bool IsSubmitting { get; set; } = false;

    private async Task HandleSubmit()
    {
        IsSubmitting = true;
        try 
        {
            Message.Subject = "Website Contact Inquiry";
            Message.Status = CollegeWebSite.Domain.Enums.InquiryStatus.New;
            
            await InquiryService.CreateInquiryAsync(Message);
            IsSubmitted = true;
        }
        catch (Exception ex)
        {
            // Simple log or notify
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void ResetForm()
    {
        Message = new();
        IsSubmitted = false;
        IsSubmitting = false;
    }
}
