@page "/faculty"
@using CollegeWebSite.Components.Public.Layout
@using CollegeWebSite.Components.Shared
@using CollegeWebSite.Services.Interfaces
@using CollegeWebSite.Domain.Entities
@layout MainLayout
@inject IFacultyService FacultyService

<SeoHead Title="Faculty | Ishika Nursing & Paramedical Studies"
         Description="Meet Ishika’s nursing and paramedical faculty — experienced educators and clinical mentors in Kendujhar, Odisha."
         Keywords="Ishika faculty, nursing teachers Kendujhar, paramedical educators Odisha, Ishika nursing staff" />

@inject ISeoService SeoService
@foreach(var faculty in FacultyList)
{
    <StructuredData JsonLd="@SeoService.GeneratePersonSchema(faculty)" />
}

<!-- Hero Section -->
<section class="relative py-24 lg:py-32 bg-slate-900 overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[50rem] h-[50rem] bg-secondary/10 rounded-full blur-[120px] -z-0"></div>
    
    <div class="container-custom relative z-10 text-center">
        <span class="inline-block px-5 py-2 rounded-full bg-secondary/20 text-secondary-light text-[12px] font-black uppercase tracking-widest border border-white/5 mb-8">
            ACADEMIC EXCELLENCE
        </span>
        <h1 class="text-4xl lg:text-5xl xl:text-6xl font-black text-white leading-tight uppercase animate-parallax">
            Meet Our <span class="text-secondary italic">Mentors.</span>
        </h1>
        <p class="text-slate-400 font-bold text-[16px] lg:text-[20px] max-w-2xl mx-auto mt-6 leading-relaxed uppercase tracking-tight">
            Guided by clinical experts and academic leaders who bridge the gap between theory and compassionate medical care.
        </p>
    </div>
</section>

<!-- Faculty Grid -->
<section class="py-24 lg:py-40 bg-white relative">
    <div class="container-custom">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 lg:gap-20">
            @if (IsLoading)
            {
                @for(int i=0; i<3; i++)
                {
                    <div class="space-y-6 animate-pulse">
                        <div class="aspect-[4/5] bg-slate-50 rounded-3xl"></div>
                        <div class="space-y-4">
                            <div class="h-6 bg-slate-50 rounded-full w-2/3"></div>
                            <div class="h-4 bg-slate-50 rounded-full w-1/3"></div>
                        </div>
                    </div>
                }
            }
            else
            {
                @foreach (var member in FacultyList)
                {
                    <div class="group space-y-6 animate-parallax">
                        <!-- Image Frame -->
                        <div class="relative aspect-[4/5] rounded-3xl border border-slate-100 overflow-hidden bg-slate-100 shadow-glass">
                            <OptimizedImage Media="@member.Photo" 
                                            Src="@(member.Photo == null ? "images/placeholder-avatar.jpg" : null)"
                                            AltText="@member.Name"
                                            Class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
                            
                            <!-- Detailed Overlay (Visible on Hover) -->
                            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm flex flex-col justify-end p-8 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0">
                                <div class="space-y-4">
                                    <div class="flex gap-3">
                                        <div class="h-10 w-10 rounded-xl bg-white/10 flex items-center justify-center text-white border border-white/20">
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                        </div>
                                         @if (!string.IsNullOrEmpty(member.Email))
                                         {
                                             <div class="h-10 w-10 rounded-xl bg-white/10 flex items-center justify-center text-white border border-white/20">
                                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                             </div>
                                         }
                                    </div>
                                    <p class="text-white text-[12px] font-bold leading-relaxed line-clamp-4 uppercase tracking-tight">
                                        @member.Bio
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="text-center lg:text-left space-y-3">
                             <span class="inline-block px-3 py-1 rounded-full bg-primary/5 text-primary text-[12px] font-black uppercase tracking-widest mb-2">
                                @member.Designation
                            </span>
                            <h3 class="text-2xl lg:text-3xl font-black text-slate-900 group-hover:text-primary transition-colors uppercase leading-none">@member.Name</h3>
                            <p class="text-slate-400 font-bold text-[12px] lg:text-[14px] uppercase tracking-widest italic leading-none">@member.Qualification</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-10 lg:py-16 bg-slate-50">
    <div class="container-custom">
        <div class="bg-slate-950 rounded-3xl p-10 lg:p-14 relative overflow-hidden text-center lg:text-left lg:flex items-center justify-between gap-10 shadow-2xl">
            <div class="absolute top-0 left-0 w-64 h-64 bg-primary/10 rounded-full blur-[100px] -translate-x-1/2 -translate-y-1/2"></div>
            
            <div class="relative z-10 max-w-2xl space-y-6">
                <h2 class="text-3xl lg:text-4xl font-black text-white leading-tight uppercase">
                    Join Our <span class="text-primary italic">Clinical Excellence.</span>
                </h2>
                <p class="text-slate-400 font-bold text-[16px] lg:text-[18px] uppercase tracking-tight">
                    Are you a clinical expert passionate about teaching? Join our elite nursing faculty.
                </p>
            </div>

            <div class="relative z-10 mt-8 lg:mt-0">
                <a href="/p/contact" class="px-8 py-4 bg-white text-slate-900 font-black text-[12px] rounded-2xl hover:bg-primary hover:text-white transition-all shadow-xl flex items-center justify-center gap-3 uppercase tracking-widest">
                    SEND INQUIRY
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </a>
            </div>
        </div>
    </div>
</section>

@code {
    private List<CollegeWebSite.Domain.Entities.Faculty> FacultyList { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
             FacultyList = await FacultyService.GetAllFacultyAsync();
        }
        finally
        {
            IsLoading = false;
        }
    }
}
